"use strict";
const http = require("http");
const https = require("https");
const PORT = 3456;
const HTML = "<!DOCTYPE html>\r\n<html lang=\"en\" class=\"dark\">\r\n<head>\r\n<meta charset=\"UTF-8\" />\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\r\n<title>mizi</title>\r\n<style>\r\n  :root {\r\n    --bg: #262624;\r\n    --sidebar: #1f1e1d;\r\n    --card: #30302e;\r\n    --card-2: #393937;\r\n    --border: #3a3a37;\r\n    --border-lt: #46453f;\r\n    --text: #f0eee6;\r\n    --dim: #b8b4a7;\r\n    --faint: #83806f;\r\n    --accent: #d97757;\r\n    --accent-hover: #e08b6d;\r\n    --on-accent: #221510;\r\n    --ok: #8bc48d;\r\n    --danger: #e5695e;\r\n    --font: ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, sans-serif;\r\n    --serif: \"Tiempos Text\", Georgia, \"Times New Roman\", serif;\r\n    --mono: ui-monospace, \"SF Mono\", \"Cascadia Code\", Menlo, Consolas, monospace;\r\n  }\r\n  * { box-sizing: border-box; margin: 0; padding: 0; }\r\n  html, body { height: 100%; }\r\n  body {\r\n    background: var(--bg);\r\n    color: var(--text);\r\n    font-family: var(--font);\r\n    font-size: 15px;\r\n    line-height: 1.55;\r\n    display: flex;\r\n    height: 100dvh;\r\n    overflow: hidden;\r\n  }\r\n  button { font-family: var(--font); }\r\n  .micro {\r\n    font-size: 11px; color: var(--faint);\r\n    font-weight: 600; letter-spacing: .02em;\r\n    padding: 0 8px;\r\n  }\r\n\r\n  /* ================= Sidebar ================= */\r\n  aside.sidebar {\r\n    width: 288px; flex-shrink: 0;\r\n    background: var(--sidebar);\r\n    border-right: 1px solid var(--border);\r\n    display: flex; flex-direction: column;\r\n    min-height: 0;\r\n    transition: margin-left .2s;\r\n  }\r\n  .sb-top { padding: 14px 14px 6px; display: flex; align-items: center; gap: 8px; }\r\n  .sb-logo {\r\n    font-family: var(--serif); font-size: 21px; font-weight: 600; letter-spacing: -0.01em;\r\n    display: flex; align-items: center; gap: 8px; color: var(--text);\r\n  }\r\n  .star { color: var(--accent); display: inline-flex; align-items: center; }\r\n  .sb-logo .star { font-size: 17px; }\r\n\r\n  .sb-nav { padding: 8px 8px 4px; display: flex; flex-direction: column; gap: 1px; }\r\n  .nav-item {\r\n    display: flex; align-items: center; gap: 10px;\r\n    background: transparent; border: none; color: var(--dim);\r\n    font-size: 13.5px; font-weight: 500;\r\n    border-radius: 8px; padding: 7px 10px;\r\n    cursor: pointer; text-align: left; width: 100%;\r\n    transition: background .1s, color .1s;\r\n  }\r\n  .nav-item:hover { background: var(--card); color: var(--text); }\r\n  .nav-item svg { flex-shrink: 0; opacity: .85; }\r\n  .nav-item.primary { color: var(--accent); font-weight: 600; }\r\n  .nav-item.primary:hover { color: var(--accent-hover); background: var(--card); }\r\n  .nav-item .badge {\r\n    margin-left: auto;\r\n    font-size: 10px; color: var(--on-accent); background: var(--accent);\r\n    border-radius: 5px; padding: 1px 6px; font-weight: 700;\r\n  }\r\n\r\n  .sb-section { padding: 12px 8px 4px; min-height: 0; display: flex; flex-direction: column; flex-shrink: 0; }\r\n  .sb-section.grow { flex: 1; min-height: 80px; }\r\n  .sb-section .micro { margin-bottom: 4px; }\r\n\r\n  /* models list in sidebar */\r\n  .model-row {\r\n    display: flex; align-items: center; gap: 9px;\r\n    background: transparent; border: none; width: 100%;\r\n    color: var(--dim); font-size: 13px;\r\n    border-radius: 8px; padding: 6px 10px;\r\n    cursor: pointer; text-align: left;\r\n    transition: background .1s;\r\n  }\r\n  .model-row:hover { background: var(--card); }\r\n  .model-row .chk {\r\n    width: 15px; height: 15px; border-radius: 4px;\r\n    border: 1.5px solid var(--faint); flex-shrink: 0;\r\n    display: grid; place-items: center;\r\n    transition: all .12s; color: transparent;\r\n  }\r\n  .model-row.on { color: var(--text); }\r\n  .model-row.on .chk { background: var(--accent); border-color: var(--accent); color: var(--on-accent); }\r\n  .model-row .fr { margin-left: auto; font-size: 9px; color: var(--faint); border: 1px solid var(--border-lt); border-radius: 4px; padding: 0 5px; font-weight: 600; letter-spacing: .05em; }\r\n  .model-row.on .fr { color: var(--accent); border-color: var(--accent); }\r\n\r\n  /* mode bar */\r\n  .composer-modes { position: relative; margin-top: 8px; }\r\n  .mode-trigger {\r\n    display: inline-flex; align-items: center; gap: 6px;\r\n    background: var(--card-2); border: 1px solid var(--border);\r\n    color: var(--text); font-size: 12px; font-weight: 600;\r\n    border-radius: 16px; padding: 4px 12px 4px 10px;\r\n    cursor: pointer; transition: all .12s; letter-spacing: .01em;\r\n  }\r\n  .mode-trigger:hover { background: var(--border); border-color: var(--border-lt); }\r\n  .mode-trigger svg { width: 12px; height: 12px; opacity: .6; flex-shrink: 0; }\r\n  .mode-trigger .mode-tag {\r\n    font-size: 9px; font-weight: 700; letter-spacing: .06em;\r\n    background: var(--accent); color: var(--on-accent);\r\n    border-radius: 4px; padding: 1px 5px; margin-left: 2px;\r\n  }\r\n  .mode-dropdown {\r\n    display: none; position: absolute; bottom: calc(100% + 6px); left: 0;\r\n    background: var(--card); border: 1px solid var(--border-lt);\r\n    border-radius: 12px; padding: 4px;\r\n    box-shadow: 0 8px 32px rgba(0,0,0,.4); z-index: 100;\r\n    min-width: 180px;\r\n  }\r\n  .mode-dropdown.open { display: block; }\r\n  .mode-opt {\r\n    display: flex; align-items: center; gap: 8px;\r\n    width: 100%; background: transparent; border: none;\r\n    color: var(--dim); font-size: 13px; font-weight: 500;\r\n    border-radius: 8px; padding: 8px 10px;\r\n    cursor: pointer; text-align: left;\r\n    transition: background .1s;\r\n  }\r\n  .mode-opt:hover { background: var(--card-2); color: var(--text); }\r\n  .mode-opt.on { color: var(--text); }\r\n  .mode-opt .check { width: 14px; flex-shrink: 0; color: var(--accent); opacity: 0; }\r\n  .mode-opt.on .check { opacity: 1; }\r\n  .mode-opt .mode-name { flex: 1; }\r\n  .mode-opt .mode-desc { font-size: 11px; color: var(--faint); font-weight: 400; }\r\n\r\n  /* map */\r\n  .map-wrap { margin: 6px 8px 0; border: 1px solid var(--border); border-radius: 10px; background: #21201e; overflow: hidden; position: relative; }\r\n  #mapCanvas { display: block; width: 100%; height: 165px; }\r\n  .live-ind {\r\n    position: absolute; top: 8px; right: 10px;\r\n    display: flex; align-items: center; gap: 5px;\r\n    font-size: 9.5px; font-family: var(--mono); color: var(--faint);\r\n  }\r\n  .live-ind .ld { width: 6px; height: 6px; border-radius: 50%; background: var(--faint); }\r\n  .live-ind.on .ld { background: var(--ok); animation: blink 1s infinite; }\r\n  @keyframes blink { 0%,100% { opacity: 1; } 50% { opacity: .3; } }\r\n\r\n  /* activity */\r\n  .act-list { flex: 1; overflow-y: auto; margin-top: 6px; padding: 0 8px 8px; display: flex; flex-direction: column; gap: 4px; min-height: 60px; }\r\n  .act-empty { color: var(--faint); font-size: 12px; padding: 4px 10px; }\r\n  .act {\r\n    background: var(--card); border: 1px solid var(--border);\r\n    border-radius: 8px; padding: 6px 9px; font-size: 11px;\r\n  }\r\n  .act-top { display: flex; align-items: center; gap: 6px; font-family: var(--mono); }\r\n  .act-top .am { color: var(--text); font-weight: 600; font-size: 10.5px; }\r\n  .act-top .ap { margin-left: auto; color: var(--faint); font-size: 9px; text-transform: uppercase; letter-spacing: .05em; flex-shrink: 0; }\r\n  .act-status { color: var(--dim); font-size: 10.5px; margin-top: 2px; font-family: var(--mono); word-break: break-word; font-variant-numeric: tabular-nums; }\r\n  .act.err .act-status { color: var(--danger); }\r\n  .mdot { width: 6px; height: 6px; border-radius: 50%; background: var(--faint); flex-shrink: 0; }\r\n  .mdot.run { background: var(--accent); animation: blink 1s infinite; }\r\n  .mdot.ok { background: var(--ok); }\r\n  .mdot.err { background: var(--danger); }\r\n\r\n  /* sidebar footer — API key */\r\n  .sb-foot {\r\n    border-top: 1px solid var(--border);\r\n    padding: 12px; display: flex; flex-direction: column; gap: 8px;\r\n  }\r\n  .key-row { display: flex; align-items: center; gap: 7px; }\r\n  .conn-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--faint); flex-shrink: 0; }\r\n  .conn-dot.ok { background: var(--ok); box-shadow: 0 0 6px var(--ok); }\r\n  .conn-dot.err { background: var(--danger); }\r\n  .key-input {\r\n    flex: 1; min-width: 0;\r\n    background: var(--card); border: 1px solid var(--border-lt);\r\n    color: var(--text); border-radius: 8px;\r\n    padding: 7px 10px; font-size: 12px; font-family: var(--mono);\r\n    outline: none; transition: border-color .15s;\r\n  }\r\n  .key-input:focus { border-color: var(--accent); }\r\n  .btn {\r\n    background: var(--accent); color: var(--on-accent);\r\n    border: none; border-radius: 8px;\r\n    padding: 7px 13px; font-size: 12.5px; font-weight: 600;\r\n    cursor: pointer; transition: background .15s; white-space: nowrap;\r\n  }\r\n  .btn:hover { background: var(--accent-hover); }\r\n  .btn:disabled { opacity: .4; cursor: not-allowed; }\r\n  .key-note { font-size: 10.5px; color: var(--faint); padding: 0 2px; }\r\n\r\n  /* ================= Main column ================= */\r\n  .main-col { flex: 1; display: flex; flex-direction: column; min-width: 0; position: relative; }\r\n\r\n  .top-bar {\r\n    display: none;\r\n    align-items: center; gap: 10px;\r\n    padding: 10px 14px;\r\n    border-bottom: 1px solid var(--border);\r\n  }\r\n  .icon-btn {\r\n    background: transparent; border: none; color: var(--dim);\r\n    width: 32px; height: 32px; border-radius: 8px; cursor: pointer;\r\n    display: grid; place-items: center;\r\n  }\r\n  .icon-btn:hover { background: var(--card); color: var(--text); }\r\n\r\n  main { flex: 1; overflow-y: auto; scroll-behavior: smooth; min-height: 0; }\r\n  .thread {\r\n    max-width: 780px; margin: 0 auto;\r\n    padding: 28px 24px 20px;\r\n    display: flex; flex-direction: column; gap: 22px;\r\n  }\r\n\r\n  /* ---- hero (empty state, Claude-style) ---- */\r\n  .hero {\r\n    max-width: 780px; margin: 0 auto;\r\n    min-height: 100%;\r\n    display: flex; flex-direction: column; justify-content: center;\r\n    padding: 24px; gap: 26px;\r\n  }\r\n  .greeting {\r\n    font-family: var(--serif);\r\n    font-size: 42px; font-weight: 500; letter-spacing: -0.015em;\r\n    text-align: center; color: var(--text);\r\n    display: flex; align-items: center; justify-content: center; gap: 14px;\r\n    text-wrap: balance;\r\n  }\r\n  .greeting .star { color: var(--accent); font-size: 30px; flex-shrink: 0; }\r\n  body.chatting .hero { display: none; }\r\n\r\n  /* ---- composer (Claude-style card) ---- */\r\n  .composer-dock { flex-shrink: 0; padding: 0 24px 18px; }\r\n  body:not(.chatting) .composer-dock { display: none; }\r\n  .composer {\r\n    max-width: 780px; margin: 0 auto; width: 100%;\r\n    background: var(--card);\r\n    border: 1px solid var(--border-lt);\r\n    border-radius: 22px;\r\n    padding: 14px 16px 10px;\r\n    box-shadow: 0 4px 24px rgba(0,0,0,.28);\r\n    transition: border-color .15s;\r\n  }\r\n  .composer:focus-within { border-color: #57564f; }\r\n  .composer textarea {\r\n    width: 100%; background: transparent; border: none; outline: none;\r\n    color: var(--text); resize: none;\r\n    font-family: var(--font); font-size: 15.5px; line-height: 1.5;\r\n    max-height: 190px; min-height: 26px;\r\n  }\r\n  .composer textarea::placeholder { color: var(--faint); }\r\n  .composer-row { display: flex; align-items: center; gap: 8px; margin-top: 10px; }\r\n  .plus-btn {\r\n    width: 30px; height: 30px; border-radius: 50%;\r\n    background: transparent; border: 1px solid var(--border-lt);\r\n    color: var(--dim); cursor: pointer;\r\n    display: grid; place-items: center; flex-shrink: 0;\r\n  }\r\n  .plus-btn:hover { background: var(--card-2); color: var(--text); }\r\n  .team-label {\r\n    margin-left: auto;\r\n    font-size: 12.5px; color: var(--dim); font-weight: 500;\r\n    display: flex; align-items: center; gap: 5px;\r\n    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;\r\n  }\r\n  .team-label .n { color: var(--text); font-weight: 600; }\r\n  .send-btn {\r\n    width: 32px; height: 32px; border-radius: 50%;\r\n    background: var(--accent); color: var(--on-accent);\r\n    border: none; cursor: pointer;\r\n    display: grid; place-items: center; flex-shrink: 0;\r\n    transition: background .15s, opacity .15s;\r\n  }\r\n  .send-btn:hover { background: var(--accent-hover); }\r\n  .send-btn:disabled { opacity: .35; cursor: not-allowed; }\r\n  .status-line {\r\n    max-width: 780px; margin: 6px auto 0;\r\n    font-size: 11px; color: var(--faint); font-family: var(--mono);\r\n    min-height: 14px; padding: 0 6px;\r\n  }\r\n  .status-line .working { color: var(--accent); }\r\n\r\n  /* suggestion pills under hero composer */\r\n  .pills { display: flex; justify-content: center; gap: 8px; flex-wrap: wrap; }\r\n  .pill {\r\n    display: inline-flex; align-items: center; gap: 7px;\r\n    background: transparent; border: 1px solid var(--border-lt);\r\n    color: var(--dim); border-radius: 10px;\r\n    padding: 7px 14px; font-size: 13px; font-weight: 500;\r\n    cursor: pointer; transition: background .12s, color .12s;\r\n  }\r\n  .pill:hover { background: var(--card); color: var(--text); }\r\n\r\n  /* ================= Messages ================= */\r\n  .msg { display: flex; flex-direction: column; gap: 4px; }\r\n  .msg.user { align-items: flex-end; }\r\n  .msg.user .bubble {\r\n    max-width: 80%;\r\n    background: var(--card); border: 1px solid var(--border);\r\n    border-radius: 16px; padding: 11px 16px;\r\n    white-space: pre-wrap; word-break: break-word;\r\n  }\r\n  .msg.mizi .bubble {\r\n    font-family: var(--serif);\r\n    font-size: 18px; line-height: 1.72;\r\n    color: var(--text); letter-spacing: .002em;\r\n    white-space: pre-wrap; word-break: break-word;\r\n  }\r\n  .msg .who {\r\n    font-size: 12px; color: var(--faint); padding: 0 4px;\r\n    display: flex; align-items: center; gap: 6px; font-weight: 500;\r\n  }\r\n  .msg .who .star { color: var(--accent); font-size: 11px; }\r\n\r\n  .bubble pre {\r\n    background: #1e1d1b; border: 1px solid var(--border); border-radius: 12px;\r\n    padding: 14px 15px; overflow-x: auto;\r\n    font-family: var(--mono); font-size: 12.5px; line-height: 1.55;\r\n    margin: 14px 0; white-space: pre;\r\n  }\r\n  .bubble code { font-family: var(--mono); font-size: 13.5px; background: #1e1d1b; padding: 1.5px 6px; border-radius: 5px; }\r\n  .bubble pre code { background: transparent; padding: 0; }\r\n  .bubble h3 { font-family: var(--serif); font-size: 22px; margin: 22px 0 8px; font-weight: 600; letter-spacing: -0.01em; }\r\n  .bubble h3:first-child { margin-top: 2px; }\r\n  .bubble strong { font-weight: 650; color: var(--text); }\r\n  .bubble ul { padding-left: 26px; margin: 8px 0; }\r\n  .bubble li { margin: 4px 0; padding-left: 2px; }\r\n\r\n  /* say bubbles (models speaking mid-run) */\r\n  .say-note {\r\n    display: flex; gap: 10px; align-items: flex-start;\r\n    background: var(--card); border: 1px solid var(--border);\r\n    border-left: 3px solid var(--accent);\r\n    border-radius: 12px; padding: 10px 14px;\r\n    font-size: 14px; color: var(--dim);\r\n  }\r\n  .say-note .sm { color: var(--accent); font-weight: 600; font-size: 12.5px; flex-shrink: 0; margin-top: 1px; }\r\n\r\n  /* ================= Group chat window ================= */\r\n  .gchat {\r\n    border: 1px solid var(--border); border-radius: 16px;\r\n    background: var(--card); overflow: hidden;\r\n    display: flex; flex-direction: column; max-height: 440px;\r\n  }\r\n  .gchat-head {\r\n    display: flex; align-items: center; gap: 8px;\r\n    padding: 10px 14px; border-bottom: 1px solid var(--border);\r\n    background: color-mix(in srgb, var(--card) 60%, var(--bg));\r\n  }\r\n  .gchat-head .gc-title { font-size: 13.5px; font-weight: 600; color: var(--text); }\r\n  .gchat-head .gc-sub { font-size: 12px; color: var(--faint); margin-left: auto; }\r\n  .gc-avatars { display: flex; }\r\n  .gc-avatars .av { margin-left: -6px; border: 2px solid var(--card); }\r\n  .gc-avatars .av:first-child { margin-left: 0; }\r\n  .gchat-body {\r\n    padding: 14px; display: flex; flex-direction: column; gap: 12px;\r\n    overflow-y: auto;\r\n  }\r\n  .av {\r\n    width: 26px; height: 26px; border-radius: 50%; flex-shrink: 0;\r\n    display: flex; align-items: center; justify-content: center;\r\n    font-size: 11px; font-weight: 700; color: #12110e;\r\n  }\r\n  .gc-row { display: flex; gap: 9px; align-items: flex-start; animation: gcIn .25s ease; }\r\n  @keyframes gcIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }\r\n  .gc-msg { display: flex; flex-direction: column; gap: 3px; max-width: 82%; }\r\n  .gc-name { font-size: 12px; font-weight: 600; }\r\n  .gc-bubble {\r\n    background: var(--bg); border: 1px solid var(--border);\r\n    border-radius: 4px 14px 14px 14px; padding: 8px 12px;\r\n    font-size: 14px; line-height: 1.5; color: var(--text); text-wrap: pretty;\r\n    white-space: pre-wrap; word-break: break-word;\r\n  }\r\n  .gc-row.kind-ask .gc-bubble { border-style: dashed; }\r\n  .gc-row.kind-answer .gc-bubble { background: color-mix(in srgb, var(--ok) 12%, var(--bg)); border-color: color-mix(in srgb, var(--ok) 40%, var(--border)); }\r\n  .gc-row.kind-whisper .gc-bubble { font-style: italic; color: var(--dim); }\r\n  .gc-row.kind-say .gc-bubble { border-color: color-mix(in srgb, var(--accent) 45%, var(--border)); }\r\n  .gc-tag {\r\n    font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: .04em;\r\n    padding: 1px 6px; border-radius: 999px; align-self: flex-start;\r\n    background: var(--border); color: var(--faint);\r\n  }\r\n  .gc-tag.to { background: color-mix(in srgb, var(--accent) 22%, transparent); color: var(--accent); }\r\n  .gc-meta { font-size: 11px; color: var(--faint); }\r\n  .gc-typing .gc-bubble { color: var(--faint); font-style: italic; }\r\n  .gc-typing .dots::after { content: \"…\"; animation: gcDots 1.2s steps(4,end) infinite; }\r\n  @keyframes gcDots { 0% { content: \"\"; } 33% { content: \".\"; } 66% { content: \"..\"; } 100% { content: \"…\"; } }\r\n\r\n  /* ================= Agent trace ================= */\r\n  .trace { display: flex; flex-direction: column; gap: 4px; }\r\n  .trace-header {\r\n    font-size: 13.5px; color: var(--faint);\r\n    display: flex; align-items: center; gap: 8px; cursor: pointer; user-select: none;\r\n    font-weight: 500; padding: 2px 0;\r\n  }\r\n  .trace-header:hover { color: var(--dim); }\r\n  .trace-header .tchev { transition: transform .2s; font-size: 9px; }\r\n  .trace.open .trace-header .tchev { transform: rotate(90deg); }\r\n  /* connected vertical rail down the left of the whole thinking timeline */\r\n  .trace-feed {\r\n    display: none; flex-direction: column; gap: 14px;\r\n    margin: 8px 0 2px; padding: 2px 0 2px 26px;\r\n    border-left: 1px solid var(--border);\r\n    position: relative;\r\n  }\r\n  .trace.open .trace-feed { display: flex; }\r\n\r\n  .thought {\r\n    font-family: var(--serif);\r\n    font-size: 17px; line-height: 1.62;\r\n    color: var(--text); text-wrap: pretty;\r\n  }\r\n  .thought.dim { color: var(--dim); font-size: 14.5px; font-family: var(--font); }\r\n\r\n  /* collapsible full-thinking entry (Claude/v0 style): icon + one-line preview,\r\n     expand to reveal EVERY word the model generated — nothing truncated */\r\n  .tthink { display: flex; flex-direction: column; }\r\n  .tthink-head {\r\n    display: flex; align-items: center; gap: 9px;\r\n    cursor: pointer; user-select: none;\r\n    font-size: 13px; color: var(--faint); font-weight: 500;\r\n  }\r\n  .tthink-head:hover { color: var(--dim); }\r\n  .tthink-head .tt-ico {\r\n    width: 24px; height: 24px; border-radius: 50%;\r\n    background: var(--bg); margin-left: -38px; z-index: 1;\r\n    display: grid; place-items: center; color: var(--faint); flex-shrink: 0;\r\n  }\r\n  .tthink-head .tt-label {\r\n    white-space: nowrap; overflow: hidden; text-overflow: ellipsis; min-width: 0;\r\n  }\r\n  .tthink-head .tt-chev { margin-left: auto; flex-shrink: 0; font-size: 9px; transition: transform .2s; }\r\n  .tthink.open .tthink-head .tt-chev { transform: rotate(90deg); }\r\n  .tthink-body {\r\n    display: none; position: relative;\r\n    margin: 10px 0 0; padding: 0;\r\n    font-family: var(--serif); font-size: 16.5px; line-height: 1.62;\r\n    color: var(--dim); text-wrap: pretty; white-space: pre-wrap; word-break: break-word;\r\n  }\r\n  .tthink.open .tthink-body { display: block; }\r\n  /* long thoughts clamp with a fade + \"Show more\" (Claude behavior) */\r\n  .tthink-body.clamped { max-height: 150px; overflow: hidden; }\r\n  .tthink-body.clamped::after {\r\n    content: \"\"; position: absolute; left: 0; right: 0; bottom: 0; height: 56px;\r\n    background: linear-gradient(to bottom, transparent, var(--bg));\r\n    pointer-events: none;\r\n  }\r\n  .tt-more {\r\n    display: none; margin-top: 8px;\r\n    background: none; border: none; padding: 0; cursor: pointer;\r\n    font-family: var(--font); font-size: 13px; font-weight: 600; color: var(--accent);\r\n  }\r\n  .tt-more:hover { color: var(--accent-hover); }\r\n  .tthink.open .tt-more.avail { display: inline-block; }\r\n\r\n  .tcall { display: flex; gap: 12px; position: relative; }\r\n  .tcall .ticon {\r\n    width: 24px; height: 24px; border-radius: 50%;\r\n    background: var(--bg); margin-left: -38px; z-index: 1;\r\n    display: grid; place-items: center;\r\n    flex-shrink: 0; margin-top: -1px; color: var(--faint);\r\n  }\r\n  .tcall.running .ticon { color: var(--accent); }\r\n  .tcall.ok .ticon { color: var(--ok); }\r\n  .tcall.err .ticon { color: var(--danger); }\r\n  .tcall.running .ticon svg { animation: spin 1.4s linear infinite; }\r\n  @keyframes spin { to { transform: rotate(360deg); } }\r\n\r\n  .tcall .tbody { flex: 1; min-width: 0; }\r\n  .tcall .trow { display: flex; align-items: baseline; gap: 10px; cursor: pointer; user-select: none; }\r\n  .tcall .ttitle { font-size: 13.5px; color: var(--dim); font-weight: 500; }\r\n  .tcall .ttitle .tm { color: var(--text); font-weight: 600; }\r\n  .tcall .tmeta {\r\n    margin-left: auto; flex-shrink: 0;\r\n    font-size: 11px; color: var(--faint); font-family: var(--mono);\r\n    font-variant-numeric: tabular-nums;\r\n  }\r\n  .tcall .tpanel {\r\n    margin-top: 8px;\r\n    background: var(--card); border: 1px solid var(--border);\r\n    border-radius: 10px;\r\n    max-height: 210px; overflow-y: auto;\r\n    padding: 10px 13px;\r\n    font-family: var(--mono); font-size: 11.5px; color: var(--dim);\r\n    white-space: pre-wrap; word-break: break-word;\r\n    display: none;\r\n  }\r\n  .tcall.has-out .tpanel { display: block; }\r\n  .tcall.collapsed .tpanel { display: none; }\r\n  .tpanel .reason { color: var(--faint); font-style: italic; }\r\n  .tpanel .errtext { color: var(--danger); }\r\n\r\n  /* tool-use chips (talk / whisper / say / create_file) */\r\n  .tool-use {\r\n    display: flex; align-items: flex-start; gap: 10px;\r\n    background: var(--card); border: 1px solid var(--border);\r\n    border-radius: 10px; padding: 8px 12px;\r\n    font-size: 12.5px; color: var(--dim);\r\n  }\r\n  .tool-use .tu-tag {\r\n    flex-shrink: 0; font-family: var(--mono); font-size: 10.5px;\r\n    color: var(--accent); border: 1px solid var(--border-lt);\r\n    border-radius: 6px; padding: 1px 7px; margin-top: 1px;\r\n    text-transform: lowercase;\r\n  }\r\n  .tool-use .tu-body { min-width: 0; word-break: break-word; }\r\n  .tool-use .tu-body .tu-from { color: var(--text); font-weight: 600; }\r\n  .tool-use .tu-body .tu-to { color: var(--accent); }\r\n\r\n  .iter-banner {\r\n    display: flex; align-items: center; gap: 10px;\r\n    font-size: 10.5px; font-family: var(--mono);\r\n    color: var(--faint); text-transform: uppercase; letter-spacing: .08em;\r\n  }\r\n  .iter-banner::before, .iter-banner::after { content: \"\"; flex: 1; height: 1px; background: var(--border); }\r\n  .iter-banner .pass { color: var(--ok); }\r\n  .iter-banner .fail { color: var(--danger); }\r\n  /* mode markers — replaces the old per-turn banners */\r\n  .mode-banner {\r\n    display: flex; align-items: center; gap: 12px; margin: 4px 0;\r\n    font-size: 12px; font-weight: 700; font-family: var(--mono);\r\n    text-transform: uppercase; letter-spacing: .1em;\r\n  }\r\n  .mode-banner::before, .mode-banner::after { content: \"\"; flex: 1; height: 1px; }\r\n  .mode-banner.plan { color: var(--accent); }\r\n  .mode-banner.plan::before, .mode-banner.plan::after { background: color-mix(in srgb, var(--accent) 45%, transparent); }\r\n  .mode-banner.work { color: var(--ok); }\r\n  .mode-banner.work::before, .mode-banner.work::after { background: color-mix(in srgb, var(--ok) 45%, transparent); }\r\n  .mode-banner.talk { color: var(--text); }\r\n  .mode-banner.talk::before, .mode-banner.talk::after { background: color-mix(in srgb, var(--text) 32%, transparent); }\r\n\r\n  /* ---- model-swap recommendation (shown when a teammate fails) ---- */\r\n  .rec-swap {\r\n    display: flex; align-items: flex-start; gap: 11px;\r\n    background: color-mix(in srgb, var(--danger) 9%, var(--card));\r\n    border: 1px solid color-mix(in srgb, var(--danger) 40%, var(--border));\r\n    border-left: 3px solid var(--danger);\r\n    border-radius: 12px; padding: 11px 14px;\r\n  }\r\n  .rec-swap .rs-ico { color: var(--danger); flex-shrink: 0; margin-top: 1px; display: grid; place-items: center; }\r\n  .rec-swap .rs-body { flex: 1; min-width: 0; font-size: 13px; color: var(--dim); line-height: 1.5; }\r\n  .rec-swap .rs-body b { color: var(--text); font-weight: 650; }\r\n  .rec-swap .rs-pick { color: var(--accent); font-weight: 650; }\r\n  .rec-swap .rs-actions { display: flex; align-items: center; gap: 8px; margin-top: 9px; flex-wrap: wrap; }\r\n  .rec-swap .rs-btn {\r\n    background: var(--accent); color: var(--on-accent);\r\n    border: none; border-radius: 8px; padding: 6px 13px;\r\n    font-size: 12px; font-weight: 600; cursor: pointer; transition: background .15s;\r\n  }\r\n  .rec-swap .rs-btn:hover { background: var(--accent-hover); }\r\n  .rec-swap .rs-btn.ghost { background: transparent; color: var(--dim); border: 1px solid var(--border-lt); }\r\n  .rec-swap .rs-btn.ghost:hover { background: var(--card-2); color: var(--text); }\r\n  .rec-swap .rs-done { font-size: 12px; color: var(--ok); font-weight: 600; }\r\n  .rec-swap.resolved { opacity: .7; border-left-color: var(--ok); }\r\n\r\n  .test-list { display: flex; flex-direction: column; gap: 5px; }\r\n  .test-item {\r\n    display: flex; align-items: flex-start; gap: 8px;\r\n    font-size: 12px; font-family: var(--mono); color: var(--dim);\r\n    background: var(--card); border: 1px solid var(--border);\r\n    border-radius: 8px; padding: 6px 10px;\r\n  }\r\n  .test-item .ti { flex-shrink: 0; font-weight: 700; }\r\n  .test-item.pass .ti { color: var(--ok); }\r\n  .test-item.fail .ti { color: var(--danger); }\r\n\r\n  /* ---- Real-time tool indicator (shown while model is streaming) ---- */\r\n  .rt-tool {\r\n    display: inline-flex; align-items: center; gap: 8px;\r\n    background: color-mix(in srgb, var(--accent) 10%, var(--card));\r\n    border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--border));\r\n    border-radius: 10px; padding: 6px 12px;\r\n    font-size: 12.5px; color: var(--dim); margin: 4px 0;\r\n    animation: pulse 1.5s ease-in-out infinite;\r\n  }\r\n  .rt-tool .rt-ico { color: var(--accent); display: flex; align-items: center; flex-shrink: 0; }\r\n  .rt-tool .rt-name { color: var(--text); font-weight: 600; font-family: var(--mono); font-size: 12px; }\r\n  .rt-tool .rt-args {\r\n    color: var(--faint); font-family: var(--mono); font-size: 11.5px;\r\n    max-width: 400px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;\r\n  }\r\n  .rt-tool .rt-shimmer {\r\n    width: 60px; height: 3px; border-radius: 2px; flex-shrink: 0;\r\n    background: linear-gradient(90deg, var(--border) 0%, var(--accent) 50%, var(--border) 100%);\r\n    background-size: 200% 100%;\r\n    animation: shimmer 1.2s ease infinite;\r\n  }\r\n\r\n  /* Explore badge — shown when models read/search files */\r\n  .explore-badge {\r\n    display: inline-flex; align-items: center; gap: 6px;\r\n    background: var(--card); border: 1px solid var(--border);\r\n    border-radius: 8px; padding: 5px 11px;\r\n    font-size: 12px; color: var(--dim); font-weight: 500;\r\n    margin: 4px 0;\r\n  }\r\n  .explore-badge .eb-ico { color: var(--faint); display: flex; align-items: center; }\r\n  .explore-badge .eb-label { color: var(--text); font-weight: 600; }\r\n  .explore-badge .eb-sep { color: var(--border-lt); margin: 0 2px; }\r\n  .explore-badge .eb-count { color: var(--accent); font-weight: 600; }\r\n\r\n  /* Command run line — shown when models execute shell commands */\r\n  .cmd-run {\r\n    display: flex; align-items: flex-start; gap: 8px;\r\n    font-family: var(--mono); font-size: 12px; color: var(--dim);\r\n    background: var(--card); border: 1px solid var(--border);\r\n    border-radius: 8px; padding: 6px 10px; margin: 4px 0;\r\n  }\r\n  .cmd-run .cr-ico { color: var(--faint); flex-shrink: 0; margin-top: 1px; }\r\n  .cmd-run .cr-label { color: var(--text); font-weight: 600; flex-shrink: 0; }\r\n  .cmd-run .cr-cmd { color: var(--dim); word-break: break-all; }\r\n\r\n  /* files */\r\n  .files { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; }\r\n  .file-card {\r\n    display: flex; align-items: center; gap: 12px;\r\n    background: var(--card); border: 1px solid var(--border-lt);\r\n    border-radius: 12px; padding: 9px 13px; font-size: 12.5px;\r\n  }\r\n  .file-card .fname { font-family: var(--mono); color: var(--text); font-size: 12px; }\r\n  .file-card .fsize { color: var(--faint); font-size: 10.5px; }\r\n  .file-card button {\r\n    background: var(--accent); color: var(--on-accent);\r\n    border: none; border-radius: 7px;\r\n    padding: 5px 11px; font-size: 11.5px; font-weight: 600; cursor: pointer;\r\n  }\r\n  .file-card button:hover { background: var(--accent-hover); }\r\n\r\n  /* ---- Shining / pulse animations (replace spin) ---- */\r\n  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: .35; } }\r\n  @keyframes shimmer {\r\n    0% { background-position: -200% 0; }\r\n    100% { background-position: 200% 0; }\r\n  }\r\n  @keyframes glow { 0%,100% { box-shadow: 0 0 4px var(--accent); } 50% { box-shadow: 0 0 14px var(--accent); } }\r\n  .shimmer-bar {\r\n    height: 3px; border-radius: 2px; width: 80px;\r\n    background: linear-gradient(90deg, var(--border) 0%, var(--accent) 50%, var(--border) 100%);\r\n    background-size: 200% 100%;\r\n    animation: shimmer 1.5s ease infinite;\r\n  }\r\n  .pulse-dot {\r\n    width: 8px; height: 8px; border-radius: 50%;\r\n    background: var(--accent);\r\n    animation: pulse 1.2s ease-in-out infinite;\r\n  }\r\n  .glow-ring {\r\n    width: 28px; height: 28px; border-radius: 50%;\r\n    border: 2px solid var(--accent);\r\n    animation: glow 1.5s ease-in-out infinite;\r\n    display: grid; place-items: center;\r\n  }\r\n\r\n  /* ---- File activity (show every file created/edited) ---- */\r\n  .file-activity {\r\n    display: flex; align-items: center; gap: 8px;\r\n    font-size: 12.5px; padding: 5px 10px; margin: 3px 0;\r\n    border-radius: 8px; background: var(--card); border: 1px solid var(--border);\r\n  }\r\n  .file-activity .fa-ico { flex-shrink: 0; display: flex; align-items: center; }\r\n  .file-activity .fa-name { font-family: var(--mono); color: var(--text); font-weight: 500; }\r\n  .file-activity .fa-diff { margin-left: auto; font-family: var(--mono); font-size: 11px; font-weight: 600; }\r\n  .file-activity .fa-diff .added { color: var(--ok); }\r\n  .file-activity .fa-diff .removed { color: var(--danger); }\r\n  .file-activity.created .fa-ico { color: var(--ok); }\r\n  .file-activity.edited .fa-ico { color: var(--accent); }\r\n\r\n  /* ---- Stop buttons ---- */\r\n  .stop-btn {\r\n    width: 32px; height: 32px; border-radius: 50%;\r\n    background: var(--danger); color: #fff;\r\n    border: none; cursor: pointer;\r\n    display: grid; place-items: center; flex-shrink: 0;\r\n    transition: background .15s, transform .1s;\r\n  }\r\n  .stop-btn:hover { background: #c94a40; transform: scale(1.08); }\r\n  .stop-btn.model-stop {\r\n    position: absolute; top: 8px; right: 8px;\r\n    width: 26px; height: 26px; z-index: 5;\r\n    background: color-mix(in srgb, var(--danger) 80%, var(--card));\r\n    border: 1px solid var(--danger);\r\n  }\r\n\r\n  /* ---- Reply-to-model button ---- */\r\n  .reply-btn {\r\n    background: transparent; border: 1px solid var(--border-lt);\r\n    color: var(--dim); border-radius: 6px;\r\n    padding: 3px 8px; font-size: 11px; font-weight: 500;\r\n    cursor: pointer; display: inline-flex; align-items: center; gap: 4px;\r\n    transition: all .12s; margin-top: 4px;\r\n  }\r\n  .reply-btn:hover { background: var(--card); color: var(--text); border-color: var(--accent); }\r\n\r\n  /* ---- Preview panel (right side) ---- */\r\n  .preview-panel {\r\n    position: fixed; right: 0; top: 0; bottom: 0;\r\n    width: 420px; background: var(--sidebar);\r\n    border-left: 1px solid var(--border);\r\n    display: flex; flex-direction: column;\r\n    z-index: 50; transform: translateX(100%);\r\n    transition: transform .2s ease;\r\n  }\r\n  .preview-panel.open { transform: translateX(0); }\r\n  .pp-head {\r\n    display: flex; align-items: center; gap: 8px;\r\n    padding: 10px 14px; border-bottom: 1px solid var(--border);\r\n  }\r\n  .pp-head .pp-title { font-size: 13px; font-weight: 600; color: var(--text); flex: 1; }\r\n  .pp-head .pp-close {\r\n    background: transparent; border: none; color: var(--dim);\r\n    cursor: pointer; width: 28px; height: 28px; border-radius: 6px;\r\n    display: grid; place-items: center;\r\n  }\r\n  .pp-head .pp-close:hover { background: var(--card); color: var(--text); }\r\n  .pp-tabs { display: flex; border-bottom: 1px solid var(--border); }\r\n  .pp-tab {\r\n    flex: 1; padding: 8px; text-align: center;\r\n    font-size: 12px; font-weight: 500; color: var(--dim);\r\n    background: transparent; border: none; cursor: pointer;\r\n    border-bottom: 2px solid transparent;\r\n    transition: all .12s;\r\n  }\r\n  .pp-tab.active { color: var(--accent); border-bottom-color: var(--accent); }\r\n  .pp-tab:hover { color: var(--text); }\r\n  .pp-body { flex: 1; overflow-y: auto; padding: 12px; }\r\n  .pp-body pre {\r\n    background: #1e1d1b; border: 1px solid var(--border);\r\n    border-radius: 10px; padding: 14px;\r\n    font-family: var(--mono); font-size: 12px; line-height: 1.55;\r\n    overflow-x: auto; white-space: pre; color: var(--dim);\r\n  }\r\n\r\n  /* ---- In-browser terminal ---- */\r\n  .term-panel {\r\n    border: 1px solid var(--border); border-radius: 12px;\r\n    background: #1a1918; overflow: hidden;\r\n    display: flex; flex-direction: column; max-height: 300px;\r\n    margin-top: 8px;\r\n  }\r\n  .term-head {\r\n    display: flex; align-items: center; gap: 8px;\r\n    padding: 8px 12px; border-bottom: 1px solid var(--border);\r\n    background: #21201e;\r\n  }\r\n  .term-head .th-title { font-size: 12px; font-weight: 600; color: var(--text); flex: 1; font-family: var(--mono); }\r\n  .term-body {\r\n    padding: 10px 12px; font-family: var(--mono); font-size: 12px;\r\n    color: var(--ok); overflow-y: auto; max-height: 220px;\r\n    white-space: pre-wrap; word-break: break-all;\r\n  }\r\n  .term-body .t-prompt { color: var(--accent); }\r\n  .term-body .t-err { color: var(--danger); }\r\n  .term-input-row {\r\n    display: flex; align-items: center; gap: 6px;\r\n    padding: 6px 12px; border-top: 1px solid var(--border);\r\n  }\r\n  .term-input-row .t-prompt { color: var(--accent); font-family: var(--mono); font-size: 12px; }\r\n  .term-input {\r\n    flex: 1; background: transparent; border: none; outline: none;\r\n    color: var(--text); font-family: var(--mono); font-size: 12px;\r\n  }\r\n\r\n  /* ---- Question / answer UI ---- */\r\n  .question-box {\r\n    background: color-mix(in srgb, var(--accent) 8%, var(--card));\r\n    border: 1px solid color-mix(in srgb, var(--accent) 35%, var(--border));\r\n    border-radius: 12px; padding: 14px; margin: 6px 0;\r\n  }\r\n  .question-box .q-text { font-size: 14px; color: var(--text); font-weight: 500; margin-bottom: 10px; }\r\n  .question-box .q-from { font-size: 11px; color: var(--faint); margin-bottom: 6px; font-weight: 600; }\r\n  .q-options { display: flex; flex-direction: column; gap: 6px; }\r\n  .q-opt {\r\n    background: var(--card); border: 1px solid var(--border-lt);\r\n    border-radius: 8px; padding: 8px 12px;\r\n    font-size: 13px; color: var(--dim); cursor: pointer;\r\n    transition: all .12s; text-align: left; width: 100%;\r\n    font-family: var(--font);\r\n  }\r\n  .q-opt:hover { background: var(--card-2); color: var(--text); border-color: var(--accent); }\r\n  .q-custom {\r\n    display: flex; gap: 6px; margin-top: 6px;\r\n  }\r\n  .q-custom input {\r\n    flex: 1; background: var(--card); border: 1px solid var(--border-lt);\r\n    color: var(--text); border-radius: 8px; padding: 7px 10px;\r\n    font-size: 13px; font-family: var(--font); outline: none;\r\n  }\r\n  .q-custom input:focus { border-color: var(--accent); }\r\n  .q-custom button {\r\n    background: var(--accent); color: var(--on-accent);\r\n    border: none; border-radius: 8px; padding: 7px 14px;\r\n    font-size: 12px; font-weight: 600; cursor: pointer;\r\n  }\r\n\r\n  /* ---- Floating scroll-to-bottom button (Claude-style) ---- */\r\n  .scroll-btn {\r\n    position: absolute; left: 50%; transform: translateX(-50%);\r\n    bottom: 104px; z-index: 20;\r\n    width: 36px; height: 36px; border-radius: 50%;\r\n    background: var(--card); border: 1px solid var(--border-lt);\r\n    color: var(--dim); cursor: pointer;\r\n    display: grid; place-items: center;\r\n    box-shadow: 0 4px 18px rgba(0,0,0,.38);\r\n    opacity: 0; visibility: hidden; transition: opacity .18s, visibility .18s, background .15s;\r\n  }\r\n  .scroll-btn.show { opacity: 1; visibility: visible; }\r\n  .scroll-btn:hover { color: var(--text); background: var(--card-2); }\r\n\r\n  ::-webkit-scrollbar { width: 10px; height: 10px; }\r\n  ::-webkit-scrollbar-thumb { background: var(--border-lt); border-radius: 6px; border: 2px solid var(--bg); }\r\n  ::-webkit-scrollbar-track { background: transparent; }\r\n\r\n  @media (max-width: 900px) {\r\n    aside.sidebar {\r\n      position: fixed; left: 0; top: 0; bottom: 0; z-index: 40;\r\n      margin-left: -288px; box-shadow: 12px 0 40px rgba(0,0,0,.5);\r\n      transition: margin-left .2s;\r\n    }\r\n    aside.sidebar.open { margin-left: 0; }\r\n    .top-bar { display: flex; }\r\n    .greeting { font-size: 30px; }\r\n  }\r\n</style>\r\n</head>\r\n<body>\r\n\r\n<aside class=\"sidebar\" id=\"sidebar\">\r\n  <div class=\"sb-top\">\r\n    <div class=\"sb-logo\"><span class=\"star\"><svg width=\"1em\" height=\"1em\" viewBox=\"0 0 24 24\" fill=\"currentColor\" aria-hidden=\"true\"><path d=\"M12 1l1.7 7.1 5.3-5 -3.4 6.4 7.2-.9 -6.4 3.4 6.4 3.4 -7.2-.9 3.4 6.4 -5.3-5L12 23l-1.7-7.1 -5.3 5 3.4-6.4 -7.2.9 6.4-3.4 -6.4-3.4 7.2.9 -3.4-6.4 5.3 5z\"/></svg></span>mizi</div>\r\n  </div>\r\n\r\n  <div class=\"sb-nav\">\r\n    <button class=\"nav-item primary\" id=\"newChatBtn\">\r\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"><path d=\"M12 5v14M5 12h14\"/></svg>\r\n      New chat\r\n    </button>\r\n    <button class=\"nav-item\">\r\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z\"/></svg>\r\n      Chats\r\n    </button>\r\n    <button class=\"nav-item\" id=\"filesNav\">\r\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z\"/><polyline points=\"14 2 14 8 20 8\"/></svg>\r\n      Artifacts\r\n      <span class=\"badge\" id=\"fileCount\" style=\"display:none\">0</span>\r\n    </button>\r\n  </div>\r\n\r\n  <div class=\"sb-section\">\r\n    <span class=\"micro\">Models · combined as one</span>\r\n    <div id=\"modelList\"></div>\r\n  </div>\r\n\r\n  <div class=\"sb-section\">\r\n    <span class=\"micro\">Model map</span>\r\n    <div class=\"map-wrap\">\r\n      <canvas id=\"mapCanvas\" aria-label=\"Real-time map of models and their communication\"></canvas>\r\n      <span class=\"live-ind\" id=\"liveInd\"><span class=\"ld\"></span>idle</span>\r\n    </div>\r\n  </div>\r\n\r\n  <div class=\"sb-section grow\">\r\n    <span class=\"micro\">Live activity</span>\r\n    <div class=\"act-list\" id=\"actList\">\r\n      <div class=\"act-empty\" id=\"actEmpty\">Model calls appear here.</div>\r\n    </div>\r\n  </div>\r\n\r\n  <div class=\"sb-foot\">\r\n    <div class=\"key-row\">\r\n      <span class=\"conn-dot\" id=\"connDot\" aria-hidden=\"true\"></span>\r\n      <input class=\"key-input\" id=\"apiKey\" type=\"password\" placeholder=\"OpenCode API key\" autocomplete=\"off\" aria-label=\"OpenCode API key\" />\r\n      <button class=\"btn\" id=\"connectBtn\">Connect</button>\r\n    </div>\r\n    <span class=\"key-note\">Key stays in your browser. Free models only.</span>\r\n  </div>\r\n</aside>\r\n\r\n<div class=\"main-col\">\r\n  <div class=\"top-bar\">\r\n    <button class=\"icon-btn\" id=\"sbToggle\" aria-label=\"Toggle sidebar\">\r\n      <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"><path d=\"M3 6h18M3 12h18M3 18h18\"/></svg>\r\n    </button>\r\n    <div class=\"sb-logo\" style=\"font-size:17px\"><span class=\"star\"><svg width=\"1em\" height=\"1em\" viewBox=\"0 0 24 24\" fill=\"currentColor\" aria-hidden=\"true\"><path d=\"M12 1l1.7 7.1 5.3-5 -3.4 6.4 7.2-.9 -6.4 3.4 6.4 3.4 -7.2-.9 3.4 6.4 -5.3-5L12 23l-1.7-7.1 -5.3 5 3.4-6.4 -7.2.9 6.4-3.4 -6.4-3.4 7.2.9 -3.4-6.4 5.3 5z\"/></svg></span>mizi</div>\r\n  </div>\r\n\r\n  <main id=\"main\">\r\n    <div class=\"hero\" id=\"hero\">\r\n      <h1 class=\"greeting\"><span class=\"star\"><svg width=\"1em\" height=\"1em\" viewBox=\"0 0 24 24\" fill=\"currentColor\" aria-hidden=\"true\"><path d=\"M12 1l1.7 7.1 5.3-5 -3.4 6.4 7.2-.9 -6.4 3.4 6.4 3.4 -7.2-.9 3.4 6.4 -5.3-5L12 23l-1.7-7.1 -5.3 5 3.4-6.4 -7.2.9 6.4-3.4 -6.4-3.4 7.2.9 -3.4-6.4 5.3 5z\"/></svg></span><span id=\"greetText\">Good evening</span></h1>\r\n      <div id=\"heroComposerSlot\"></div>\r\n      <div class=\"pills\">\r\n        <button class=\"pill\" data-fill=\"Write a single-file HTML game: \">\r\n          <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"16 18 22 12 16 6\"/><polyline points=\"8 6 2 12 8 18\"/></svg>\r\n          Code\r\n        </button>\r\n        <button class=\"pill\" data-fill=\"Write \">\r\n          <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 20h9\"/><path d=\"M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z\"/></svg>\r\n          Write\r\n        </button>\r\n        <button class=\"pill\" data-fill=\"Explain, in depth: \">\r\n          <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M22 10v6M2 10l10-5 10 5-10 5z\"/><path d=\"M6 12v5c3 3 9 3 12 0v-5\"/></svg>\r\n          Learn\r\n        </button>\r\n        <button class=\"pill\" data-fill=\"Create a downloadable file that \">\r\n          <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4\"/><polyline points=\"7 10 12 15 17 10\"/><line x1=\"12\" y1=\"15\" x2=\"12\" y2=\"3\"/></svg>\r\n          Create files\r\n        </button>\r\n      </div>\r\n    </div>\r\n    <div class=\"thread\" id=\"thread\" style=\"display:none\"></div>\r\n  </main>\r\n\r\n  <button class=\"scroll-btn\" id=\"scrollBtn\" aria-label=\"Scroll to bottom\">\r\n    <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 5v14\"/><path d=\"m19 12-7 7-7-7\"/></svg>\r\n  </button>\r\n\r\n  <div class=\"composer-dock\" id=\"composerDock\"></div>\r\n</div>\r\n\r\n<!-- Preview panel (right side) -->\r\n<div class=\"preview-panel\" id=\"previewPanel\">\r\n  <div class=\"pp-head\">\r\n    <span class=\"pp-title\" id=\"ppTitle\">Preview</span>\r\n    <button class=\"pp-close\" id=\"ppClose\" aria-label=\"Close preview\">\r\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"><path d=\"M18 6 6 18\"/><path d=\"m6 6 12 12\"/></svg>\r\n    </button>\r\n  </div>\r\n  <div class=\"pp-tabs\">\r\n    <button class=\"pp-tab active\" data-tab=\"code\">Code</button>\r\n    <button class=\"pp-tab\" data-tab=\"preview\">Preview</button>\r\n    <button class=\"pp-tab\" data-tab=\"terminal\">Terminal</button>\r\n  </div>\r\n  <div class=\"pp-body\" id=\"ppBody\">\r\n    <pre id=\"ppCode\">No file selected</pre>\r\n    <iframe id=\"ppFrame\" style=\"display:none;width:100%;height:100%;border:none;border-radius:10px;\"></iframe>\r\n    <div id=\"ppTerm\" style=\"display:none;\">\r\n      <div class=\"term-panel\">\r\n        <div class=\"term-head\"><span class=\"th-title\">Terminal</span></div>\r\n        <div class=\"term-body\" id=\"termOutput\"></div>\r\n        <div class=\"term-input-row\">\r\n          <span class=\"t-prompt\">$</span>\r\n          <input class=\"term-input\" id=\"termInput\" placeholder=\"Type a command...\" autocomplete=\"off\" />\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</div>\r\n\r\n<!-- the single composer element; JS moves it between hero and dock -->\r\n<template id=\"composerTpl\"></template>\r\n\r\n<script>\r\n\"use strict\";\r\n\r\n/* ============================================================\r\n   mizi — combined AI agent, Claude-style UI\r\n   AUTONOMOUS engine: no fixed pipeline. Models take turns and\r\n   decide EVERYTHING themselves through tool calls — who works,\r\n   who acts next, when to test, when to debug, when it's done.\r\n   Tools: say / talk / whisper / create_file / assign_task /\r\n   handoff / spawn_subagent / run_tests / update_answer / done.\r\n   ============================================================ */\r\n\r\n/* Calls the API through the local proxy (node mizi.html handles CORS).\r\n   This file is fully self-contained: start the server and open localhost. */\r\nconst API_BASE = location.origin + \"/api\";\r\nconst KEY_STORE = \"mizi_api_key\";\r\nconst MAX_PLAN_STEPS = 14; /* safety cap for the PLAN chat — models decide when the plan is ready */\r\nconst MAX_WORK_STEPS = 20;  /* safety cap for WORK — models decide when to start talking */\r\nconst MAX_TALK_STEPS = 10;  /* safety cap for TALK — models decide when it's truly done */\r\n\r\nconst $ = (id) => document.getElementById(id);\r\n\r\n/* ---------------- build composer (single instance, moved between hero & dock) ---------------- */\r\nconst composerEl = document.createElement(\"div\");\r\ncomposerEl.className = \"composer\";\r\ncomposerEl.innerHTML =\r\n  '<textarea id=\"input\" rows=\"1\" placeholder=\"How can I help you today?\" aria-label=\"Message\"></textarea>' +\r\n  '<div class=\"composer-modes\" id=\"modePicker\">' +\r\n    '<button class=\"mode-trigger\" id=\"modeTrigger\">' +\r\n      '<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"><path d=\"M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5\"/></svg>' +\r\n      '<span id=\"modeLabel\">Sutizi</span>' +\r\n      '<span class=\"mode-tag\" id=\"modeTag\">normal</span>' +\r\n      '<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"m6 9 6 6 6-6\"/></svg>' +\r\n    '</button>' +\r\n    '<div class=\"mode-dropdown\" id=\"modeDropdown\">' +\r\n      '<button class=\"mode-opt\" data-mode=\"sufastizi\"><span class=\"check\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg></span><span class=\"mode-name\">SuFastizi</span><span class=\"mode-desc\">instant</span></button>' +\r\n      '<button class=\"mode-opt\" data-mode=\"fastizi\"><span class=\"check\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg></span><span class=\"mode-name\">Fastizi</span><span class=\"mode-desc\">fast</span></button>' +\r\n      '<button class=\"mode-opt on\" data-mode=\"sutizi\"><span class=\"check\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg></span><span class=\"mode-name\">Sutizi</span><span class=\"mode-desc\">normal</span></button>' +\r\n      '<button class=\"mode-opt\" data-mode=\"compactizi\"><span class=\"check\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg></span><span class=\"mode-name\">Compactizi</span><span class=\"mode-desc\">compact</span></button>' +\r\n      '<button class=\"mode-opt\" data-mode=\"xtizi\"><span class=\"check\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg></span><span class=\"mode-name\">xtizi</span><span class=\"mode-desc\">power</span></button>' +\r\n    '</div>' +\r\n  '</div>' +\r\n  '<div class=\"composer-row\">' +\r\n    '<button class=\"plus-btn\" aria-label=\"Attachments (decorative)\" tabindex=\"-1\">' +\r\n      '<svg width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"><path d=\"M12 5v14M5 12h14\"/></svg>' +\r\n    '</button>' +\r\n    '<button class=\"stop-btn\" id=\"stopAgentBtn\" style=\"display:none\" aria-label=\"Stop agent\">' +\r\n      '<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><rect x=\"6\" y=\"6\" width=\"12\" height=\"12\" rx=\"2\"/></svg>' +\r\n    '</button>' +\r\n    '<span class=\"team-label\" id=\"teamLabel\"><span class=\"n\">0</span>&nbsp;models combined</span>' +\r\n    '<button class=\"send-btn\" id=\"sendBtn\" disabled aria-label=\"Send\">' +\r\n      '<svg width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"m5 12 7-7 7 7\"/><path d=\"M12 19V5\"/></svg>' +\r\n    '</button>' +\r\n  '</div>';\r\nconst statusEl = document.createElement(\"div\");\r\nstatusEl.className = \"status-line\";\r\nstatusEl.innerHTML = '<span id=\"statusText\"></span>';\r\n$(\"heroComposerSlot\").appendChild(composerEl);\r\n$(\"heroComposerSlot\").appendChild(statusEl);\r\n\r\nconst els = {\r\n  apiKey: $(\"apiKey\"), connectBtn: $(\"connectBtn\"), connDot: $(\"connDot\"),\r\n  thread: $(\"thread\"), main: $(\"main\"), hero: $(\"hero\"),\r\n  modelList: $(\"modelList\"),\r\n  input: composerEl.querySelector(\"#input\"), sendBtn: composerEl.querySelector(\"#sendBtn\"),\r\n  teamLabel: composerEl.querySelector(\"#teamLabel\"),\r\n  statusText: statusEl.querySelector(\"#statusText\"),\r\n  actList: $(\"actList\"), actEmpty: $(\"actEmpty\"), liveInd: $(\"liveInd\"),\r\n  mapCanvas: $(\"mapCanvas\"),\r\n  composerDock: $(\"composerDock\"),\r\n  fileCount: $(\"fileCount\"),\r\n};\r\n\r\nconst state = {\r\n  key: \"\",\r\n  models: [],\r\n  selected: new Set(),\r\n  busy: false,\r\n  history: [],\r\n  activeCalls: 0,\r\n  filesMade: 0,\r\n  chatting: false,\r\n  mode: \"sutizi\",\r\n};\r\n\r\n/* greeting by local time */\r\n(function greet() {\r\n  const h = new Date().getHours();\r\n  $(\"greetText\").textContent = h < 12 ? \"Good morning\" : h < 18 ? \"Good afternoon\" : \"Good evening\";\r\n})();\r\n\r\n/* Mode dropdown */\r\nconst MODE_LABELS = { sufastizi: \"instant\", fastizi: \"fast\", sutizi: \"normal\", compactizi: \"compact\", xtizi: \"power\" };\r\n(function initModePicker() {\r\n  const trigger = $(\"modeTrigger\");\r\n  const dropdown = $(\"modeDropdown\");\r\n  const label = $(\"modeLabel\");\r\n  const tag = $(\"modeTag\");\r\n  trigger.addEventListener(\"click\", (e) => {\r\n    e.stopPropagation();\r\n    dropdown.classList.toggle(\"open\");\r\n  });\r\n  document.addEventListener(\"click\", () => dropdown.classList.remove(\"open\"));\r\n  dropdown.addEventListener(\"click\", (e) => e.stopPropagation());\r\n  document.querySelectorAll(\".mode-opt\").forEach(opt => {\r\n    opt.addEventListener(\"click\", () => {\r\n      document.querySelectorAll(\".mode-opt\").forEach(o => o.classList.remove(\"on\"));\r\n      opt.classList.add(\"on\");\r\n      state.mode = opt.dataset.mode;\r\n      label.textContent = opt.querySelector(\".mode-name\").textContent;\r\n      tag.textContent = MODE_LABELS[state.mode];\r\n      dropdown.classList.remove(\"open\");\r\n    });\r\n  });\r\n})();\r\n\r\n$(\"sbToggle\").addEventListener(\"click\", () => $(\"sidebar\").classList.toggle(\"open\"));\r\n$(\"newChatBtn\").addEventListener(\"click\", () => {\r\n  state.history = [];\r\n  els.thread.innerHTML = \"\";\r\n  enterMode(false);\r\n});\r\n\r\n/* pills fill the input */\r\ndocument.querySelectorAll(\".pill\").forEach(p => {\r\n  p.addEventListener(\"click\", () => {\r\n    els.input.value = p.dataset.fill || \"\";\r\n    els.input.focus();\r\n    autoGrow(); updateSendState();\r\n  });\r\n});\r\n\r\nfunction enterMode(chatting) {\r\n  state.chatting = chatting;\r\n  document.body.classList.toggle(\"chatting\", chatting);\r\n  els.thread.style.display = chatting ? \"\" : \"none\";\r\n  els.hero.style.display = chatting ? \"none\" : \"\";\r\n  const target = chatting ? els.composerDock : $(\"heroComposerSlot\");\r\n  target.appendChild(composerEl);\r\n  target.appendChild(statusEl);\r\n}\r\n\r\n/* ---------------- utils ---------------- */\r\n\r\nfunction esc(s) {\r\n  return String(s).replace(/&/g,\"&amp;\").replace(/</g,\"&lt;\").replace(/>/g,\"&gt;\").replace(/\"/g,\"&quot;\");\r\n}\r\nfunction shortName(id) { return id.replace(/-free$/,\"\").split(\"/\").pop(); }\r\nconst MODEL_COLORS = [\"#d97757\",\"#8bc48d\",\"#7aa2d6\",\"#e0b15e\",\"#c98ac4\",\"#5fc2b8\",\"#e5695e\",\"#b8c47a\"];\r\nconst _colorMap = {};\r\nfunction modelColor(id) {\r\n  if (_colorMap[id]) return _colorMap[id];\r\n  const c = MODEL_COLORS[Object.keys(_colorMap).length % MODEL_COLORS.length];\r\n  _colorMap[id] = c; return c;\r\n}\r\nfunction initials(id) {\r\n  const n = shortName(id).replace(/[^a-z0-9]/gi, \"\");\r\n  return (n.slice(0, 2) || \"??\").toUpperCase();\r\n}\r\nfunction setStatus(txt, working) {\r\n  els.statusText.textContent = txt || \"\";\r\n  els.statusText.className = working ? \"working\" : \"\";\r\n}\r\nfunction scrollDown() { els.main.scrollTop = els.main.scrollHeight; }\r\nfunction fmtChars(n) { return n >= 1000 ? (n/1000).toFixed(1) + \"k\" : String(n); }\r\n\r\n/* floating scroll-to-bottom button: show it whenever the user has scrolled up */\r\n(function scrollBtnSetup() {\r\n  const btn = $(\"scrollBtn\");\r\n  if (!btn) return;\r\n  const atBottom = () => els.main.scrollHeight - els.main.scrollTop - els.main.clientHeight < 80;\r\n  const sync = () => btn.classList.toggle(\"show\", state.chatting && !atBottom());\r\n  els.main.addEventListener(\"scroll\", sync, { passive: true });\r\n  btn.addEventListener(\"click\", () => { els.main.scrollTo({ top: els.main.scrollHeight, behavior: \"smooth\" }); });\r\n  window.addEventListener(\"resize\", sync);\r\n})();\r\n\r\nfunction renderMd(text) {\r\n  let t = esc(text);\r\n  t = t.replace(/```(\\w*)\\n?([\\s\\S]*?)```/g, (_, lang, code) =>\r\n    \"<pre><code>\" + code.replace(/\\n$/,\"\") + \"</code></pre>\");\r\n  t = t.replace(/`([^`\\n]+)`/g, \"<code>$1</code>\");\r\n  t = t.replace(/^### (.*)$/gm, \"<h3>$1</h3>\");\r\n  t = t.replace(/^## (.*)$/gm, \"<h3>$1</h3>\");\r\n  t = t.replace(/^# (.*)$/gm, \"<h3>$1</h3>\");\r\n  t = t.replace(/\\*\\*([^*]+)\\*\\*/g, \"<strong>$1</strong>\");\r\n  t = t.replace(/^[-*] (.*)$/gm, \"<li>$1</li>\");\r\n  t = t.replace(/(<li>[\\s\\S]*?<\\/li>)(?!\\s*<li>)/g, \"<ul>$1</ul>\");\r\n  /* collapse the blank lines that surround block elements so pre-wrap doesn't\r\n     stack literal line breaks on top of each block's own margin (Claude spacing) */\r\n  t = t.replace(/\\n*(<\\/?(?:h3|ul|pre)>)\\n*/g, \"$1\");\r\n  t = t.replace(/\\n*(<li>)/g, \"$1\").replace(/(<\\/li>)\\n*/g, \"$1\");\r\n  return t;\r\n}\r\n\r\n/* ================= Model map (canvas) ================= */\r\n\r\nconst map = (() => {\r\n  const canvas = els.mapCanvas;\r\n  const ctx = canvas.getContext(\"2d\");\r\n  const COL = { idle: \"#83806f\", busy: \"#d97757\", ok: \"#8bc48d\", err: \"#e5695e\" };\r\n  let nodes = [], pulses = [], raf = 0, W = 0, H = 0, dpr = 1;\r\n\r\n  function resize() {\r\n    dpr = Math.min(window.devicePixelRatio || 1, 2);\r\n    W = canvas.clientWidth; H = canvas.clientHeight;\r\n    canvas.width = W * dpr; canvas.height = H * dpr;\r\n    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);\r\n    layout();\r\n  }\r\n  function layout() {\r\n    const hub = nodes.find(n => n.kind === \"hub\");\r\n    if (hub) { hub.x = W / 2; hub.y = H / 2; }\r\n    const ms = nodes.filter(n => n.kind === \"model\");\r\n    const R = Math.min(W, H) / 2 - 34;\r\n    ms.forEach((n, i) => {\r\n      const a = -Math.PI / 2 + (i * 2 * Math.PI) / ms.length;\r\n      n.x = W / 2 + R * Math.cos(a);\r\n      n.y = H / 2 + R * Math.sin(a);\r\n    });\r\n    const subs = nodes.filter(n => n.kind === \"sub\");\r\n    subs.forEach((n, i) => { n.x = 28 + i * 58; n.y = H - 18; });\r\n  }\r\n  function node(id) { return nodes.find(n => n.id === id); }\r\n\r\n  function draw() {\r\n    ctx.clearRect(0, 0, W, H);\r\n    const hub = nodes.find(n => n.kind === \"hub\");\r\n    ctx.lineWidth = 1;\r\n    for (const n of nodes) {\r\n      if (n.kind === \"hub\" || !hub) continue;\r\n      ctx.strokeStyle = n.status === \"busy\" ? \"rgba(217,119,87,.45)\" : \"rgba(58,58,55,.9)\";\r\n      ctx.beginPath(); ctx.moveTo(hub.x, hub.y); ctx.lineTo(n.x, n.y); ctx.stroke();\r\n    }\r\n    const now = performance.now();\r\n    pulses = pulses.filter(p => now - p.start < p.dur);\r\n    for (const p of pulses) {\r\n      const a = node(p.from), b = node(p.to);\r\n      if (!a || !b) continue;\r\n      const t = (now - p.start) / p.dur;\r\n      const x = a.x + (b.x - a.x) * t, y = a.y + (b.y - a.y) * t;\r\n      ctx.fillStyle = p.color;\r\n      ctx.beginPath(); ctx.arc(x, y, 2.6, 0, Math.PI * 2); ctx.fill();\r\n    }\r\n    for (const n of nodes) {\r\n      const r = n.kind === \"hub\" ? 13 : n.kind === \"sub\" ? 7 : 9;\r\n      const col = COL[n.status] || COL.idle;\r\n      if (n.status === \"busy\") {\r\n        const g = 3.5 + 2.2 * Math.sin(now / 220);\r\n        ctx.strokeStyle = \"rgba(217,119,87,.35)\";\r\n        ctx.lineWidth = 2;\r\n        ctx.beginPath(); ctx.arc(n.x, n.y, r + g, 0, Math.PI * 2); ctx.stroke();\r\n      }\r\n      ctx.fillStyle = \"#21201e\";\r\n      ctx.strokeStyle = col; ctx.lineWidth = 2;\r\n      ctx.beginPath(); ctx.arc(n.x, n.y, r, 0, Math.PI * 2); ctx.fill(); ctx.stroke();\r\n      if (n.kind === \"hub\") {\r\n        ctx.fillStyle = \"#d97757\"; ctx.font = \"700 9px ui-monospace, monospace\";\r\n        ctx.textAlign = \"center\"; ctx.textBaseline = \"middle\";\r\n        ctx.fillText(\"mizi\", n.x, n.y);\r\n      }\r\n      ctx.fillStyle = \"#b8b4a7\";\r\n      ctx.font = \"9px ui-monospace, monospace\";\r\n      ctx.textAlign = \"center\"; ctx.textBaseline = \"top\";\r\n      const ly = n.y + r + 4;\r\n      ctx.fillText(n.label, n.x, Math.min(ly, H - 20));\r\n      if (n.action) {\r\n        ctx.fillStyle = n.status === \"err\" ? COL.err : \"#83806f\";\r\n        ctx.font = \"8px ui-monospace, monospace\";\r\n        ctx.fillText(n.action.slice(0, 20), n.x, Math.min(ly + 11, H - 9));\r\n      }\r\n    }\r\n    raf = requestAnimationFrame(draw);\r\n  }\r\n\r\n  window.addEventListener(\"resize\", resize);\r\n\r\n  return {\r\n    setTeam(team) {\r\n      nodes = [{ id: \"__hub\", label: \"\", x: 0, y: 0, status: \"idle\", action: \"\", kind: \"hub\" }];\r\n      for (const m of team) nodes.push({ id: m, label: shortName(m), x: 0, y: 0, status: \"idle\", action: \"\", kind: \"model\" });\r\n      resize();\r\n      cancelAnimationFrame(raf);\r\n      raf = requestAnimationFrame(draw);\r\n    },\r\n    addSub(id, label) {\r\n      if (!node(id)) { nodes.push({ id, label, x: 0, y: 0, status: \"idle\", action: \"\", kind: \"sub\" }); layout(); }\r\n    },\r\n    set(id, status, action) {\r\n      const n = node(id);\r\n      if (n) { n.status = status; n.action = action || \"\"; }\r\n    },\r\n    pulse(from, to, color) {\r\n      pulses.push({ from, to, start: performance.now(), dur: 700, color: color || \"rgba(217,119,87,.9)\" });\r\n    },\r\n    reset() {\r\n      for (const n of nodes) if (n.kind !== \"hub\") { n.status = \"idle\"; n.action = \"\"; }\r\n    },\r\n  };\r\n})();\r\n\r\n/* ---------------- Activity log ---------------- */\r\n\r\nfunction setLive(on) {\r\n  els.liveInd.className = \"live-ind\" + (on ? \" on\" : \"\");\r\n  els.liveInd.innerHTML = '<span class=\"ld\"></span>' + (on ? state.activeCalls + \" active\" : \"idle\");\r\n}\r\n\r\nconst activity = {\r\n  add(model, phase) {\r\n    els.actEmpty && els.actEmpty.remove();\r\n    els.actEmpty = null;\r\n    const div = document.createElement(\"div\");\r\n    div.className = \"act\";\r\n    div.innerHTML =\r\n      '<div class=\"act-top\"><span class=\"mdot run\"></span><span class=\"am\">' + esc(shortName(model)) + '</span><span class=\"ap\">' + esc(phase) + '</span></div>' +\r\n      '<div class=\"act-status\">queued</div>';\r\n    els.actList.appendChild(div);\r\n    els.actList.scrollTop = els.actList.scrollHeight;\r\n    const dot = div.querySelector(\".mdot\");\r\n    const status = div.querySelector(\".act-status\");\r\n    state.activeCalls++; setLive(true);\r\n    let finished = false;\r\n    const finish = () => { if (!finished) { finished = true; state.activeCalls--; setLive(state.activeCalls > 0); } };\r\n    return {\r\n      set(s) { status.textContent = s; },\r\n      ok(s) { dot.className = \"mdot ok\"; status.textContent = s; finish(); },\r\n      fail(s) { dot.className = \"mdot err\"; div.classList.add(\"err\"); status.textContent = \"error: \" + s; finish(); },\r\n    };\r\n  }\r\n};\r\n\r\n/* ---------------- API layer ---------------- */\r\n\r\n/* Free models on OpenCode Zen (verified against /zen/v1/models) */\r\nconst FREE_MODELS = [\r\n  { id: \"big-pickle\",             free: true },\r\n  { id: \"mimo-v2.5-free\",         free: true },\r\n  { id: \"north-mini-code-free\",   free: true },\r\n  { id: \"deepseek-v4-flash-free\", free: true },\r\n  { id: \"nemotron-3-ultra-free\",  free: true },\r\n];\r\n\r\n/* Mode configurations — same tools, different speed/quality tuning */\r\nconst MODES = {\r\n  sufastizi:  { max_tokens: 1536,  temperature: 0.4,  planSteps: 3,  workSteps: 4,  talkSteps: 2  },\r\n  fastizi:    { max_tokens: 3072,  temperature: 0.5,  planSteps: 6,  workSteps: 8,  talkSteps: 4  },\r\n  sutizi:     { max_tokens: 8192,  temperature: 0.7,  planSteps: 14, workSteps: 20, talkSteps: 10 },\r\n  compactizi: { max_tokens: 1024,  temperature: 0.5,  planSteps: 4,  workSteps: 5,  talkSteps: 3  },\r\n  xtizi:      { max_tokens: 16384, temperature: 0.75, planSteps: 20, workSteps: 30, talkSteps: 15 },\r\n};\r\n\r\nfunction extractText(content) {\r\n  if (typeof content === \"string\") return content;\r\n  if (Array.isArray(content)) return content.map(p => (typeof p === \"string\" ? p : (p.text || p.content || \"\"))).join(\"\");\r\n  return \"\";\r\n}\r\n\r\nasync function parseErrorResponse(res, model) {\r\n  const raw = await res.text().catch(() => \"\");\r\n  let msg = \"HTTP \" + res.status;\r\n  try {\r\n    const j = JSON.parse(raw);\r\n    const m = j.error?.message || j.error || j.message;\r\n    if (m) msg = typeof m === \"string\" ? m : JSON.stringify(m);\r\n  } catch { if (raw) msg = \"HTTP \" + res.status + \" · \" + raw.slice(0, 180); }\r\n  return shortName(model) + \": \" + msg;\r\n}\r\n\r\n/* Streaming chat call with live map/log visibility.\r\n   Free models are reasoning models: output may arrive in\r\n   delta.reasoning / reasoning_content instead of delta.content. */\r\n/* Single request/response cycle. Streams tokens, reports the finish reason.\r\n   `prefix` is text already produced by earlier continuation rounds — onUpdate\r\n   receives the FULL cumulative text so the UI never appears to restart. */\r\nasync function chatOnce(model, messages, { onUpdate, mapId, act, t0, prefix }) {\r\n  let res;\r\n  try {\r\n    res = await fetch(API_BASE + \"/chat/completions\", {\r\n      method: \"POST\",\r\n      headers: { \"Authorization\": \"Bearer \" + state.key, \"Content-Type\": \"application/json\" },\r\n      body: JSON.stringify({ model, messages, max_tokens: MODES[state.mode].max_tokens, temperature: MODES[state.mode].temperature, stream: true }),\r\n    });\r\n  } catch (e) {\r\n    /* A bare \"Failed to fetch\" TypeError from the browser almost always means the\r\n       request was blocked by CORS (the Zen API sends no Access-Control-Allow-Origin).\r\n       Explain it clearly instead of a vague \"network error\". */\r\n    const isCors = e instanceof TypeError && /fetch/i.test(e.message || \"\");\r\n    const msg = isCors\r\n      ? \"blocked by CORS — the browser can't call the Zen API directly. Run this file behind a tiny proxy (or the OpenCode CLI) that adds CORS headers.\"\r\n      : \"network — \" + (e.message || e);\r\n    act.fail(msg);\r\n    map.set(mapId, \"err\", isCors ? \"CORS blocked\" : \"network error\");\r\n    throw new Error(shortName(model) + \": \" + msg);\r\n  }\r\n  if (!res.ok) {\r\n    const msg = await parseErrorResponse(res, model);\r\n    act.fail(msg);\r\n    map.set(mapId, \"err\", \"HTTP \" + res.status);\r\n    throw new Error(msg);\r\n  }\r\n\r\n  let content = \"\", reasoning = \"\", finish = null, lastPulse = 0;\r\n  const ctype = res.headers.get(\"content-type\") || \"\";\r\n\r\n  if (ctype.includes(\"text/event-stream\") && res.body) {\r\n    const reader = res.body.getReader();\r\n    const dec = new TextDecoder();\r\n    let buf = \"\";\r\n    while (true) {\r\n      const { done, value } = await reader.read();\r\n      if (done) break;\r\n      buf += dec.decode(value, { stream: true });\r\n      let nl;\r\n      while ((nl = buf.indexOf(\"\\n\")) !== -1) {\r\n        const line = buf.slice(0, nl).trim();\r\n        buf = buf.slice(nl + 1);\r\n        if (!line.startsWith(\"data:\")) continue;\r\n        const data = line.slice(5).trim();\r\n        if (!data || data === \"[DONE]\") continue;\r\n        let j;\r\n        try { j = JSON.parse(data); } catch { continue; }\r\n        if (j.error) {\r\n          const m = j.error.message || JSON.stringify(j.error);\r\n          act.fail(m);\r\n          map.set(mapId, \"err\", \"error\");\r\n          throw new Error(shortName(model) + \": \" + m);\r\n        }\r\n        const ch = j.choices && j.choices[0];\r\n        if (!ch) continue;\r\n        if (ch.finish_reason) finish = ch.finish_reason;\r\n        const d = ch.delta || ch.message || {};\r\n        const r = d.reasoning_content ?? d.reasoning;\r\n        if (typeof r === \"string\") reasoning += r;\r\n        const c = extractText(d.content);\r\n        if (c) content += c;\r\n        const total = prefix.length + content.length + reasoning.length;\r\n        const verb = (prefix || content) ? \"writing\" : \"thinking\";\r\n        act.set(verb + \" · \" + fmtChars(total) + \" chars · \" + ((performance.now() - t0) / 1000).toFixed(1) + \"s\");\r\n        map.set(mapId, \"busy\", verb + \" \" + fmtChars(total));\r\n        const now = performance.now();\r\n        if (now - lastPulse > 450) { lastPulse = now; map.pulse(mapId, \"__hub\"); }\r\n        if (onUpdate) onUpdate(prefix + content, reasoning);\r\n      }\r\n    }\r\n  } else {\r\n    act.set(\"waiting for full response…\");\r\n    let j;\r\n    try { j = await res.json(); } catch (e) { act.fail(\"bad JSON response\"); map.set(mapId, \"err\", \"bad response\"); throw new Error(shortName(model) + \": unreadable response\"); }\r\n    if (j.error) {\r\n      const m = j.error.message || JSON.stringify(j.error);\r\n      act.fail(m);\r\n      map.set(mapId, \"err\", \"error\");\r\n      throw new Error(shortName(model) + \": \" + m);\r\n    }\r\n    const c0 = j.choices && j.choices[0];\r\n    const msg = (c0 && (c0.message || c0.delta)) || {};\r\n    finish = c0 && c0.finish_reason;\r\n    content = extractText(msg.content);\r\n    reasoning = extractText(msg.reasoning_content ?? msg.reasoning);\r\n    if (onUpdate) onUpdate(prefix + content, reasoning);\r\n  }\r\n\r\n  return { content, reasoning, finish };\r\n}\r\n\r\n/* Public call: keeps going when the model is cut off at the token limit so\r\n   long code/answers are never left half-written (\"breaking in between\"). */\r\nasync function chat(model, messages, opts = {}) {\r\n  const { phase = \"work\", onUpdate = null, mapId = model, maxContinues = 4 } = opts;\r\n  const act = activity.add(model, phase);\r\n  const t0 = performance.now();\r\n  act.set(\"POST /chat/completions …\");\r\n  map.set(mapId, \"busy\", phase);\r\n  map.pulse(\"__hub\", mapId);\r\n\r\n  let full = \"\", reasoning = \"\", rounds = 0;\r\n  let convo = messages.slice();\r\n\r\n  while (true) {\r\n    rounds++;\r\n    const r = await chatOnce(model, convo, { onUpdate, mapId, act, t0, prefix: full });\r\n    full += r.content;\r\n    if (r.reasoning) reasoning = r.reasoning;\r\n    /* continue only when truncated by length and we still have room */\r\n    if (r.finish === \"length\" && full.trim() && rounds <= maxContinues) {\r\n      act.set(\"continuing (part \" + (rounds + 1) + \") · \" + fmtChars(full.length) + \" chars…\");\r\n      /* feed the partial back so the model resumes exactly where it stopped */\r\n      const tail = full.slice(-6000);\r\n      convo = messages.concat([\r\n        { role: \"assistant\", content: tail },\r\n        { role: \"user\", content: \"Continue EXACTLY where you left off. Do not repeat anything you already wrote — output only the remaining part, seamlessly.\" },\r\n      ]);\r\n      continue;\r\n    }\r\n    break;\r\n  }\r\n\r\n  const secs = ((performance.now() - t0) / 1000).toFixed(1);\r\n  const out = full.trim() || reasoning.trim();\r\n  if (!out) {\r\n    act.fail(\"empty response\");\r\n    map.set(mapId, \"err\", \"empty\");\r\n    throw new Error(shortName(model) + \": returned an empty response\");\r\n  }\r\n  act.ok(\"done · \" + secs + \"s · \" + fmtChars(out.length) + \" chars\" + (rounds > 1 ? \" · \" + rounds + \" parts\" : \"\"));\r\n  map.set(mapId, \"ok\", \"done \" + secs + \"s\");\r\n  map.pulse(mapId, \"__hub\", \"rgba(139,196,141,.9)\");\r\n  return out;\r\n}\r\n\r\nasync function chatAllSettled(jobs) {\r\n  const results = await Promise.allSettled(jobs.map(j => chat(j.model, j.messages, j.opts)));\r\n  return results.map((r, i) => ({\r\n    model: jobs[i].model,\r\n    ok: r.status === \"fulfilled\",\r\n    text: r.status === \"fulfilled\" ? r.value : \"\",\r\n    error: r.status === \"rejected\" ? String((r.reason && r.reason.message) || r.reason || \"unknown error\") : null,\r\n  }));\r\n}\r\n\r\n/* ---------------- Local code testing ---------------- */\r\n\r\nfunction localTest(text) {\r\n  const results = [];\r\n  const blocks = [...text.matchAll(/```(\\w*)[^\\n]*\\n([\\s\\S]*?)```/g)];\r\n  for (const b of blocks) {\r\n    const lang = (b[1] || \"\").toLowerCase();\r\n    const code = b[2];\r\n    if (!code.trim()) continue;\r\n    if (lang === \"js\" || lang === \"javascript\") {\r\n      try { new Function(code); results.push({ pass: true, msg: \"JS block parses (\" + fmtChars(code.length) + \" chars)\" }); }\r\n      catch (e) { results.push({ pass: false, msg: \"JS syntax error: \" + e.message }); }\r\n    } else if (lang === \"json\") {\r\n      try { JSON.parse(code); results.push({ pass: true, msg: \"JSON block valid\" }); }\r\n      catch (e) { results.push({ pass: false, msg: \"Invalid JSON: \" + e.message }); }\r\n    } else if (lang === \"html\" || (lang === \"\" && /^\\s*<!DOCTYPE html/i.test(code))) {\r\n      const scripts = [...code.matchAll(/<script[^>]*>([\\s\\S]*?)<\\/script>/gi)];\r\n      let jsOk = true;\r\n      for (const s of scripts) {\r\n        try { new Function(s[1]); } catch (e) { jsOk = false; results.push({ pass: false, msg: \"HTML inline <script> error: \" + e.message }); }\r\n      }\r\n      if (jsOk) results.push({ pass: true, msg: \"HTML block ok (\" + scripts.length + \" script tag(s) parse)\" });\r\n    }\r\n  }\r\n  return { results };\r\n}\r\n\r\n/* ---------------- Connect flow ---------------- */\r\n\r\nels.connectBtn.addEventListener(\"click\", connect);\r\nels.apiKey.addEventListener(\"keydown\", (e) => {\r\n  if (e.key === \"Enter\" && !e.isComposing && e.keyCode !== 229) connect();\r\n});\r\n\r\nstate.models = FREE_MODELS.slice();\r\nstate.selected = new Set(FREE_MODELS.slice(0, 3).map(m => m.id));\r\nrenderModelList();\r\nmap.setTeam([...state.selected]);\r\n\r\nconst savedKey = localStorage.getItem(KEY_STORE);\r\nif (savedKey) { els.apiKey.value = savedKey; connect(); }\r\n\r\nfunction connect() {\r\n  const key = els.apiKey.value.trim();\r\n  if (!key) { setStatus(\"enter an API key first\"); return; }\r\n  state.key = key;\r\n  localStorage.setItem(KEY_STORE, key);\r\n  els.connDot.className = \"conn-dot ok\";\r\n  setStatus(\"connected · \" + state.models.length + \" free models ready\");\r\n  updateSendState();\r\n}\r\n\r\nfunction renderModelList() {\r\n  els.modelList.innerHTML = \"\";\r\n  for (const m of state.models) {\r\n    const row = document.createElement(\"button\");\r\n    row.type = \"button\";\r\n    row.className = \"model-row\" + (state.selected.has(m.id) ? \" on\" : \"\");\r\n    row.setAttribute(\"aria-pressed\", state.selected.has(m.id) ? \"true\" : \"false\");\r\n    row.innerHTML =\r\n      '<span class=\"chk\"><svg width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg></span>' +\r\n      esc(shortName(m.id)) +\r\n      (m.free ? '<span class=\"fr\">FREE</span>' : \"\");\r\n    row.addEventListener(\"click\", () => {\r\n      if (state.selected.has(m.id)) state.selected.delete(m.id);\r\n      else state.selected.add(m.id);\r\n      row.classList.toggle(\"on\");\r\n      row.setAttribute(\"aria-pressed\", state.selected.has(m.id) ? \"true\" : \"false\");\r\n      map.setTeam([...state.selected]);\r\n      updateSendState();\r\n    });\r\n    els.modelList.appendChild(row);\r\n  }\r\n  updateSendState();\r\n}\r\n\r\nfunction updateSendState() {\r\n  const n = state.selected.size;\r\n  els.teamLabel.innerHTML = '<span class=\"n\">' + n + \"</span>&nbsp;model\" + (n === 1 ? \"\" : \"s\") + \" combined\";\r\n  els.sendBtn.disabled = state.busy || !state.key || n === 0 || !els.input.value.trim();\r\n}\r\n\r\n/* ---------------- Composer behavior ---------------- */\r\n\r\nfunction autoGrow() {\r\n  els.input.style.height = \"auto\";\r\n  els.input.style.height = Math.min(els.input.scrollHeight, 190) + \"px\";\r\n}\r\nels.input.addEventListener(\"input\", () => { autoGrow(); updateSendState(); });\r\nels.input.addEventListener(\"keydown\", (e) => {\r\n  if (e.key === \"Enter\" && !e.shiftKey) {\r\n    if (e.isComposing || e.keyCode === 229) return;\r\n    e.preventDefault();\r\n    if (!els.sendBtn.disabled) run();\r\n  }\r\n});\r\nels.sendBtn.addEventListener(\"click\", run);\r\n\r\n/* ---------------- UI builders ---------------- */\r\n\r\nfunction addUserMsg(text) {\r\n  const div = document.createElement(\"div\");\r\n  div.className = \"msg user\";\r\n  div.innerHTML = '<div class=\"bubble\"></div>';\r\n  div.querySelector(\".bubble\").textContent = text;\r\n  els.thread.appendChild(div);\r\n  scrollDown();\r\n}\r\n\r\nfunction addSayNote(model, message) {\r\n  const div = document.createElement(\"div\");\r\n  div.className = \"say-note\";\r\n  div.innerHTML = '<span class=\"sm\"></span><span class=\"say-body\"></span>';\r\n  div.querySelector(\".sm\").textContent = shortName(model) + \" says:\";\r\n  div.querySelector(\".say-body\").textContent = message;\r\n  els.thread.appendChild(div);\r\n  scrollDown();\r\n}\r\n\r\nconst ICONS = {\r\n  brain: '<svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M12 6v6l4 2\"/></svg>',\r\n  code: '<svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"16 18 22 12 16 6\"/><polyline points=\"8 6 2 12 8 18\"/></svg>',\r\n  test: '<svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M9 11l3 3L22 4\"/><path d=\"M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11\"/></svg>',\r\n  bug: '<svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"8\" y=\"6\" width=\"8\" height=\"14\" rx=\"4\"/><path d=\"m19 7-3 2\"/><path d=\"m5 7 3 2\"/><path d=\"m19 19-3-2\"/><path d=\"m5 19 3-2\"/><path d=\"M12 2v4\"/></svg>',\r\n  spin: '<svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"><path d=\"M21 12a9 9 0 1 1-6.219-8.56\"/></svg>',\r\n  chat: '<svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z\"/></svg>',\r\n  clock: '<svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"9\"/><path d=\"M12 7v5l3 2\"/></svg>',\r\n  search: '<svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"11\" cy=\"11\" r=\"8\"/><path d=\"m21 21-4.3-4.3\"/></svg>',\r\n  terminal: '<svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"4 17 10 11 4 5\"/><line x1=\"12\" y1=\"19\" x2=\"20\" y2=\"19\"/></svg>',\r\n  createFile: '<svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z\"/><polyline points=\"14 2 14 8 20 8\"/><line x1=\"12\" y1=\"18\" x2=\"12\" y2=\"12\"/><line x1=\"9\" y1=\"15\" x2=\"15\" y2=\"15\"/></svg>',\r\n  editFile: '<svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z\"/></svg>',\r\n  readFile: '<svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z\"/><polyline points=\"14 2 14 8 20 8\"/></svg>',\r\n  internet: '<svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M2 12h20\"/><path d=\"M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z\"/></svg>',\r\n  askUser: '<svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3\"/><path d=\"M12 17h.01\"/></svg>',\r\n  handoff: '<svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"/><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"/></svg>',\r\n  done: '<svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\"/><polyline points=\"22 4 12 14.01 9 11.01\"/></svg>',\r\n  subagent: '<svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"18\" cy=\"5\" r=\"3\"/><circle cx=\"6\" cy=\"12\" r=\"3\"/><circle cx=\"18\" cy=\"19\" r=\"3\"/><line x1=\"8.59\" y1=\"13.51\" x2=\"15.42\" y2=\"17.49\"/><line x1=\"15.41\" y1=\"6.51\" x2=\"8.59\" y2=\"10.49\"/></svg>',\r\n  preview: '<svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z\"/><circle cx=\"12\" cy=\"12\" r=\"3\"/></svg>',\r\n};\r\n\r\nfunction addTrace() {\r\n  const div = document.createElement(\"div\");\r\n  div.className = \"trace open\";\r\n  div.innerHTML =\r\n    '<div class=\"trace-header\"><span class=\"tchev\">▶</span><span class=\"th-text\">Working…</span></div>' +\r\n    '<div class=\"trace-feed\"></div>';\r\n  div.querySelector(\".trace-header\").addEventListener(\"click\", () => div.classList.toggle(\"open\"));\r\n  els.thread.appendChild(div);\r\n  scrollDown();\r\n  const feed = div.querySelector(\".trace-feed\");\r\n  const t0 = performance.now();\r\n\r\n  return {\r\n    el: div,\r\n    thought(text, dim) {\r\n      const p = document.createElement(\"div\");\r\n      p.className = \"thought\" + (dim ? \" dim\" : \"\");\r\n      p.textContent = text;\r\n      feed.appendChild(p);\r\n      scrollDown();\r\n      return p;\r\n    },\r\n    /* collapsible thinking entry — collapsed shows an icon + one-line preview,\r\n       expanding reveals EVERY word the model generated (no truncation). */\r\n    think(fullText, labelOverride) {\r\n      const wrap = document.createElement(\"div\");\r\n      wrap.className = \"tthink\"; // collapsed by default\r\n      const oneLine = fullText.replace(/\\s+/g, \" \").trim();\r\n      const label = labelOverride || (oneLine.length > 76 ? oneLine.slice(0, 76) + \"…\" : oneLine) || \"Thought for a moment\";\r\n      wrap.innerHTML =\r\n        '<div class=\"tthink-head\">' +\r\n          '<span class=\"tt-ico\">' + ICONS.clock + '</span>' +\r\n          '<span class=\"tt-label\"></span>' +\r\n          '<span class=\"tt-chev\">▶</span>' +\r\n        '</div>' +\r\n        '<div class=\"tthink-body clamped\"></div>' +\r\n        '<button class=\"tt-more\" type=\"button\">Show more</button>';\r\n      wrap.querySelector(\".tt-label\").textContent = label;\r\n      const body = wrap.querySelector(\".tthink-body\");\r\n      const more = wrap.querySelector(\".tt-more\");\r\n      body.textContent = fullText;\r\n      wrap.querySelector(\".tthink-head\").addEventListener(\"click\", () => {\r\n        wrap.classList.toggle(\"open\");\r\n        // once expanded, reveal the \"Show more\" affordance only if the text is actually clamped\r\n        if (wrap.classList.contains(\"open\") && body.scrollHeight > body.clientHeight + 4) {\r\n          more.classList.add(\"avail\");\r\n        }\r\n        scrollDown();\r\n      });\r\n      more.addEventListener(\"click\", () => {\r\n        const clamped = body.classList.toggle(\"clamped\");\r\n        more.textContent = clamped ? \"Show more\" : \"Show less\";\r\n        scrollDown();\r\n      });\r\n      feed.appendChild(wrap);\r\n      scrollDown();\r\n      return wrap;\r\n    },\r\n    banner(html) {\r\n      const b = document.createElement(\"div\");\r\n      b.className = \"iter-banner\";\r\n      b.innerHTML = html;\r\n      feed.appendChild(b);\r\n      scrollDown();\r\n    },\r\n    /* recommendation card: a teammate failed → suggest swapping in a free model\r\n       that ISN'T part of the current task, and let the user apply it in one click. */\r\n    recommend(failedModel, candidate, reason, onSwap) {\r\n      const d = document.createElement(\"div\");\r\n      d.className = \"rec-swap\";\r\n      d.innerHTML =\r\n        '<span class=\"rs-ico\">' + ICONS.bug + '</span>' +\r\n        '<div class=\"rs-body\">' +\r\n          '<b></b> failed<span class=\"rs-reason\"></span>. ' +\r\n          'Try replacing it with <span class=\"rs-pick\"></span> — a free model not used in this task.' +\r\n          '<div class=\"rs-actions\">' +\r\n            '<button class=\"rs-btn\" type=\"button\">Swap in <span class=\"rs-pickb\"></span></button>' +\r\n            '<button class=\"rs-btn ghost\" type=\"button\">Dismiss</button>' +\r\n          '</div>' +\r\n        '</div>';\r\n      d.querySelector(\".rs-body > b\").textContent = shortName(failedModel);\r\n      d.querySelector(\".rs-reason\").textContent = reason ? \" (\" + reason + \")\" : \"\";\r\n      d.querySelector(\".rs-pick\").textContent = shortName(candidate);\r\n      d.querySelector(\".rs-pickb\").textContent = shortName(candidate);\r\n      const actions = d.querySelector(\".rs-actions\");\r\n      d.querySelector(\".rs-btn:not(.ghost)\").addEventListener(\"click\", () => {\r\n        onSwap && onSwap();\r\n        d.classList.add(\"resolved\");\r\n        actions.innerHTML = '<span class=\"rs-done\">✓ Swapped ' + esc(shortName(failedModel)) + \" → \" + esc(shortName(candidate)) + \" for your next run</span>\";\r\n      });\r\n      d.querySelector(\".rs-btn.ghost\").addEventListener(\"click\", () => {\r\n        d.classList.add(\"resolved\");\r\n        actions.innerHTML = '<span class=\"rs-done\" style=\"color:var(--faint)\">Dismissed</span>';\r\n      });\r\n      feed.appendChild(d);\r\n      scrollDown();\r\n    },\r\n    mode(kind, label) {\r\n      const b = document.createElement(\"div\");\r\n      b.className = \"mode-banner \" + kind;\r\n      b.textContent = label;\r\n      feed.appendChild(b);\r\n      scrollDown();\r\n    },\r\n    tests(items) {\r\n      const wrap = document.createElement(\"div\");\r\n      wrap.className = \"test-list\";\r\n      for (const it of items) {\r\n        const d = document.createElement(\"div\");\r\n        d.className = \"test-item \" + (it.pass ? \"pass\" : \"fail\");\r\n        d.innerHTML = '<span class=\"ti\">' + (it.pass ? \"✓\" : \"✕\") + \"</span><span></span>\";\r\n        d.querySelector(\"span:last-child\").textContent = it.msg;\r\n        wrap.appendChild(d);\r\n      }\r\n      feed.appendChild(wrap);\r\n      scrollDown();\r\n    },\r\n    /* tool-use chip: talk / whisper / say / create_file */\r\n    toolUse(tool, from, body, to) {\r\n      const d = document.createElement(\"div\");\r\n      d.className = \"tool-use\";\r\n      d.innerHTML = '<span class=\"tu-tag\"></span><span class=\"tu-body\"><span class=\"tu-from\"></span>' + (to ? ' → <span class=\"tu-to\"></span>' : \"\") + ': <span class=\"tu-msg\"></span></span>';\r\n      d.querySelector(\".tu-tag\").textContent = tool;\r\n      d.querySelector(\".tu-from\").textContent = shortName(from);\r\n      if (to) d.querySelector(\".tu-to\").textContent = shortName(to);\r\n      d.querySelector(\".tu-msg\").textContent = body.length > 300 ? body.slice(0, 300) + \"…\" : body;\r\n      feed.appendChild(d);\r\n      scrollDown();\r\n    },\r\n    /* Explore badge — shown when a model reads/searches files */\r\n    explore(label, count) {\r\n      const d = document.createElement(\"div\");\r\n      d.className = \"explore-badge\";\r\n      d.innerHTML =\r\n        '<span class=\"eb-ico\">' + ICONS.search + '</span>' +\r\n        '<span class=\"eb-label\">' + esc(label || \"Explore\") + '</span>' +\r\n        '<span class=\"eb-sep\">·</span>' +\r\n        '<span class=\"eb-count\">' + esc(count || \"1 file\") + '</span>';\r\n      feed.appendChild(d);\r\n      scrollDown();\r\n    },\r\n    /* Command run — shown when a model executes a shell command */\r\n    cmdRun(command) {\r\n      const d = document.createElement(\"div\");\r\n      d.className = \"cmd-run\";\r\n      d.innerHTML =\r\n        '<span class=\"cr-ico\">' + ICONS.terminal + '</span>' +\r\n        '<span class=\"cr-label\">Ran</span>' +\r\n        '<span class=\"cr-cmd\"></span>';\r\n      d.querySelector(\".cr-cmd\").textContent = command;\r\n      feed.appendChild(d);\r\n      scrollDown();\r\n    },\r\n    /* File activity — shows every file created/edited with diff counts */\r\n    fileActivity(action, fileName, added, removed) {\r\n      const d = document.createElement(\"div\");\r\n      d.className = \"file-activity \" + action;\r\n      const ico = action === \"created\" ? ICONS.createFile : ICONS.editFile;\r\n      d.innerHTML =\r\n        '<span class=\"fa-ico\">' + ico + '</span>' +\r\n        '<span class=\"fa-name\"></span>' +\r\n        '<span class=\"fa-diff\"><span class=\"added\"></span> <span class=\"removed\"></span></span>';\r\n      d.querySelector(\".fa-name\").textContent = fileName;\r\n      d.querySelector(\".added\").textContent = added || \"\";\r\n      d.querySelector(\".removed\").textContent = removed || \"\";\r\n      feed.appendChild(d);\r\n      scrollDown();\r\n    },\r\n    /* Search results — shown when internet_search returns */\r\n    searchResults(query, results) {\r\n      const d = document.createElement(\"div\");\r\n      d.className = \"tool-use\";\r\n      d.innerHTML =\r\n        '<span class=\"tu-tag\">' + ICONS.internet + ' search</span>' +\r\n        '<span class=\"tu-body\"><span class=\"tu-msg\"></span></span>';\r\n      d.querySelector(\".tu-msg\").textContent = query + \" → \" + results;\r\n      feed.appendChild(d);\r\n      scrollDown();\r\n    },\r\n    /* User question — shown when agent asks the user */\r\n    userQuestion(model, question, options, onAnswer) {\r\n      const d = document.createElement(\"div\");\r\n      d.className = \"question-box\";\r\n      let html = '<div class=\"q-from\">' + ICONS.askUser + ' ' + esc(shortName(model)) + ' asks:</div>';\r\n      html += '<div class=\"q-text\"></div>';\r\n      html += '<div class=\"q-options\"></div>';\r\n      html += '<div class=\"q-custom\"><input class=\"q-custom-input\" placeholder=\"Type your answer...\" /><button class=\"q-custom-btn\">Send</button></div>';\r\n      d.innerHTML = html;\r\n      d.querySelector(\".q-text\").textContent = question;\r\n      const optWrap = d.querySelector(\".q-options\");\r\n      if (options && options.length) {\r\n        for (const opt of options) {\r\n          const btn = document.createElement(\"button\");\r\n          btn.className = \"q-opt\";\r\n          btn.textContent = opt;\r\n          btn.addEventListener(\"click\", () => { onAnswer(opt); d.remove(); });\r\n          optWrap.appendChild(btn);\r\n        }\r\n      }\r\n      d.querySelector(\".q-custom-btn\").addEventListener(\"click\", () => {\r\n        const val = d.querySelector(\".q-custom-input\").value.trim();\r\n        if (val) { onAnswer(val); d.remove(); }\r\n      });\r\n      d.querySelector(\".q-custom-input\").addEventListener(\"keydown\", (e) => {\r\n        if (e.key === \"Enter\") { const val = d.querySelector(\".q-custom-input\").value.trim(); if (val) { onAnswer(val); d.remove(); } }\r\n      });\r\n      feed.appendChild(d);\r\n      scrollDown();\r\n    },\r\n    /* ---- group chat window: friends talking to each other ---- */\r\n    ensureChat(team) {\r\n      if (this._gc) return this._gc;\r\n      const win = document.createElement(\"div\");\r\n      win.className = \"gchat\";\r\n      const avatars = team.map(m =>\r\n        '<span class=\"av\" style=\"background:' + modelColor(m) + '\" title=\"' + esc(shortName(m)) + '\">' + initials(m) + '</span>'\r\n      ).join(\"\");\r\n      win.innerHTML =\r\n        '<div class=\"gchat-head\">' +\r\n          '<div class=\"gc-avatars\">' + avatars + '</div>' +\r\n          '<span class=\"gc-title\">Team chat</span>' +\r\n          '<span class=\"gc-sub\">' + team.length + ' friends</span>' +\r\n        '</div>' +\r\n        '<div class=\"gchat-body\"></div>';\r\n      feed.appendChild(win);\r\n      scrollDown();\r\n      this._gc = { win, body: win.querySelector(\".gchat-body\") };\r\n      return this._gc;\r\n    },\r\n    chat(from, text, opts = {}) {\r\n      const gc = this._gc || this.ensureChat(this._team || [from]);\r\n      const { kind = \"talk\", to = null } = opts;\r\n      const row = document.createElement(\"div\");\r\n      row.className = \"gc-row kind-\" + kind;\r\n      const av = '<span class=\"av\" style=\"background:' + modelColor(from) + '\">' + initials(from) + '</span>';\r\n      const tagLabel = kind === \"ask\" ? \"asks\" : kind === \"answer\" ? \"replies\" : kind === \"whisper\" ? \"whispers\" : kind === \"say\" ? \"to user\" : null;\r\n      const tag = to\r\n        ? '<span class=\"gc-tag to\">→ ' + esc(shortName(to)) + '</span>'\r\n        : (tagLabel && kind !== \"answer\" && kind !== \"ask\" ? '<span class=\"gc-tag\">' + tagLabel + '</span>' : \"\");\r\n      row.innerHTML =\r\n        av +\r\n        '<div class=\"gc-msg\">' +\r\n          '<span class=\"gc-name\" style=\"color:' + modelColor(from) + '\">' + esc(shortName(from)) +\r\n            (to ? ' ' + tag : (tag || \"\")) + '</span>' +\r\n          '<div class=\"gc-bubble\"></div>' +\r\n        '</div>';\r\n      row.querySelector(\".gc-bubble\").textContent = text;\r\n      gc.body.appendChild(row);\r\n      gc.body.scrollTop = gc.body.scrollHeight;\r\n      scrollDown();\r\n    },\r\n    setTeam(team) { this._team = team; this.ensureChat(team); },\r\n    call(title, model, icon) {\r\n      const c = document.createElement(\"div\");\r\n      c.className = \"tcall running\";\r\n      c.innerHTML =\r\n        '<div class=\"ticon\">' + (ICONS[icon] || ICONS.spin) + '</div>' +\r\n        '<div class=\"tbody\">' +\r\n          '<div class=\"trow\"><span class=\"ttitle\">' + esc(title) + ' <span class=\"tm\">' + esc(shortName(model)) + '</span></span><span class=\"tmeta\">starting…</span></div>' +\r\n          '<div class=\"tpanel\"><span class=\"reason\"></span><span class=\"outp\"></span></div>' +\r\n        '</div>';\r\n      feed.appendChild(c);\r\n      scrollDown();\r\n      c.querySelector(\".trow\").addEventListener(\"click\", () => c.classList.toggle(\"collapsed\"));\r\n      const meta = c.querySelector(\".tmeta\");\r\n      const panel = c.querySelector(\".tpanel\");\r\n      const rEl = c.querySelector(\".reason\");\r\n      const oEl = c.querySelector(\".outp\");\r\n      const tc0 = performance.now();\r\n      /* keep every word — the panel scrolls and is collapsible, so no truncation */\r\n      const trim = (t) => t;\r\n      return {\r\n        update(content, reasoning) {\r\n          if (content || reasoning) c.classList.add(\"has-out\");\r\n          meta.textContent = (content ? \"writing\" : \"thinking\") + \" · \" + fmtChars(content.length + reasoning.length) + \" · \" + ((performance.now() - tc0) / 1000).toFixed(0) + \"s\";\r\n          rEl.textContent = content ? \"\" : trim(reasoning);\r\n          oEl.textContent = trim(content);\r\n          panel.scrollTop = panel.scrollHeight;\r\n        },\r\n        ok(finalText, metaText) {\r\n          c.className = \"tcall ok has-out\";\r\n          meta.textContent = metaText || (fmtChars(finalText.length) + \" chars · \" + ((performance.now() - tc0) / 1000).toFixed(1) + \"s\");\r\n          rEl.textContent = \"\";\r\n          oEl.textContent = trim(finalText);\r\n          scrollDown();\r\n        },\r\n        fail(msg) {\r\n          c.className = \"tcall err has-out\";\r\n          meta.textContent = \"failed\";\r\n          rEl.textContent = \"\";\r\n          oEl.innerHTML = '<span class=\"errtext\"></span>';\r\n          oEl.querySelector(\".errtext\").textContent = msg;\r\n          scrollDown();\r\n        },\r\n        collapse() { c.classList.add(\"collapsed\"); },\r\n      };\r\n    },\r\n    finish(label) {\r\n      const secs = Math.round((performance.now() - t0) / 1000);\r\n      const th = div.querySelector(\".th-text\");\r\n      th.textContent = \"Thought for \" + secs + \"s\";\r\n      if (label) th.title = label;\r\n      div.classList.remove(\"open\");\r\n    },\r\n    reopen() { div.classList.add(\"open\"); },\r\n  };\r\n}\r\n\r\nfunction addMiziMsg(html, files) {\r\n  const div = document.createElement(\"div\");\r\n  div.className = \"msg mizi\";\r\n  div.innerHTML = '<span class=\"who\"><span class=\"star\"><svg width=\"1em\" height=\"1em\" viewBox=\"0 0 24 24\" fill=\"currentColor\" aria-hidden=\"true\"><path d=\"M12 1l1.7 7.1 5.3-5 -3.4 6.4 7.2-.9 -6.4 3.4 6.4 3.4 -7.2-.9 3.4 6.4 -5.3-5L12 23l-1.7-7.1 -5.3 5 3.4-6.4 -7.2.9 6.4-3.4 -6.4-3.4 7.2.9 -3.4-6.4 5.3 5z\"/></svg></span>mizi</span><div class=\"bubble\"></div>';\r\n  div.querySelector(\".bubble\").innerHTML = html;\r\n  if (files && files.length) {\r\n    const wrap = document.createElement(\"div\");\r\n    wrap.className = \"files\";\r\n    for (const f of files) {\r\n      const card = document.createElement(\"div\");\r\n      card.className = \"file-card\";\r\n      card.innerHTML = '<div><div class=\"fname\">' + esc(f.name) + '</div><div class=\"fsize\">' + f.content.length + \" bytes</div></div>\";\r\n      const btn = document.createElement(\"button\");\r\n      btn.textContent = \"Download\";\r\n      btn.addEventListener(\"click\", () => {\r\n        const blob = new Blob([f.content], { type: \"text/plain;charset=utf-8\" });\r\n        const url = URL.createObjectURL(blob);\r\n        const a = document.createElement(\"a\");\r\n        a.href = url; a.download = f.name;\r\n        document.body.appendChild(a); a.click(); a.remove();\r\n        setTimeout(() => URL.revokeObjectURL(url), 4000);\r\n      });\r\n      card.appendChild(btn);\r\n      /* Preview button */\r\n      const pvBtn = document.createElement(\"button\");\r\n      pvBtn.textContent = \"Preview\";\r\n      pvBtn.style.background = \"var(--card-2)\";\r\n      pvBtn.style.color = \"var(--dim)\";\r\n      pvBtn.style.border = \"1px solid var(--border-lt)\";\r\n      pvBtn.addEventListener(\"click\", () => openPreview(f.name, f.content));\r\n      card.appendChild(pvBtn);\r\n      wrap.appendChild(card);\r\n    }\r\n    div.querySelector(\".bubble\").appendChild(wrap);\r\n  }\r\n  /* Reply-to-agent button */\r\n  const replyBtn = document.createElement(\"button\");\r\n  replyBtn.className = \"reply-btn\";\r\n  replyBtn.innerHTML = ICONS.chat + ' Reply to mizi';\r\n  replyBtn.addEventListener(\"click\", () => {\r\n    els.input.value = \"@mizi \";\r\n    els.input.focus();\r\n    autoGrow(); updateSendState();\r\n  });\r\n  div.appendChild(replyBtn);\r\n  els.thread.appendChild(div);\r\n  scrollDown();\r\n}\r\n\r\n/* ---------------- File extraction ---------------- */\r\nfunction extractFiles(text) {\r\n  const files = [];\r\n  const clean = text.replace(/```file:([^\\n`]+)\\n([\\s\\S]*?)```/g, (_, name, content) => {\r\n    files.push({ name: name.trim(), content: content.replace(/\\n$/,\"\") });\r\n    return \"```\\n\" + \"[file created: \" + name.trim() + \"]\" + \"\\n```\";\r\n  });\r\n  return { clean, files };\r\n}\r\n\r\nfunction bumpFileCount(n) {\r\n  state.filesMade += n;\r\n  els.fileCount.style.display = state.filesMade ? \"\" : \"none\";\r\n  els.fileCount.textContent = state.filesMade;\r\n}\r\n\r\n/* ============================================================\r\n   AUTONOMOUS AGENT ENGINE\r\n   No pipeline, no fixed iterations. Models take turns; each\r\n   turn the acting model decides everything via tool calls.\r\n   ============================================================ */\r\n\r\nconst TOOL_NAMES = \"say|talk|whisper|chat|ask|create_file|edit_file|read_file|internet_search|ask_user|assign_task|co_work|complete_task|handoff|spawn_subagent|run_tests|update_answer|plan_ready|start_talk|done\";\r\n/* Matches only the START of a tool call — the explicit \"TOOL:name\" form (primary,\r\n   paren optional) or a bare \"name(\" at line-start (fallback, paren required so we\r\n   don't grab prose words like \"ask\"/\"done\"). Neither consumes the \"(\" — parseTools\r\n   peeks ahead and either balanced-scans \"(...)\" args OR, when the model forgot the\r\n   parens entirely (e.g. `TOOL:chat Team, thanks…`), takes the rest of the line. */\r\nconst TOOL_START_RE = new RegExp(\"TOOL:\\\\s*(\" + TOOL_NAMES + \")(?![a-z_])\", \"gi\");\r\nconst BARE_START_RE = new RegExp(\"(?:^|\\\\n)[ \\\\t>*_`\\\\-]*(\" + TOOL_NAMES + \")(?![a-z_])(?=\\\\s*\\\\()\", \"gi\");\r\n\r\n/* Walk forward from the opening \"(\" tracking paren depth while respecting quoted\r\n   strings (so parens/quotes inside a message don't confuse us). Returns where the\r\n   args end and whether a real closing \")\" was found. Two safety stops for malformed\r\n   output (missing \")\" / unbalanced quotes):\r\n     • a new \"TOOL:\" marker outside quotes — tool calls never nest, so it always\r\n       terminates the current call (fixes two ask() calls jammed on one line where\r\n       the first never closed its paren);\r\n     • otherwise the first newline / end of text, so we never swallow later lines. */\r\nfunction scanArgsEnd(text, openIdx) {\r\n  let depth = 0, firstNL = -1, quote = null;\r\n  for (let i = openIdx; i < text.length; i++) {\r\n    const c = text[i];\r\n    if (quote) {\r\n      if (c === \"\\\\\") { i++; continue; }   // skip escaped char inside a string\r\n      if (c === quote) quote = null;\r\n      continue;\r\n    }\r\n    // a fresh tool marker starts a new call — end this one here (unclosed)\r\n    if ((c === \"T\" || c === \"t\") && i > openIdx && text.slice(i, i + 5).toUpperCase() === \"TOOL:\") {\r\n      return { end: i, closed: false };\r\n    }\r\n    if (c === '\"' || c === \"'\" || c === \"`\") { quote = c; continue; }\r\n    if (c === \"(\") depth++;\r\n    else if (c === \")\") { if (--depth === 0) return { end: i, closed: true }; }\r\n    else if (c === \"\\n\" && firstNL === -1) firstNL = i;\r\n  }\r\n  return { end: firstNL === -1 ? text.length : firstNL, closed: false };\r\n}\r\n\r\n/* Make sloppy model formatting parseable: normalize smart quotes and strip the\r\n   markdown emphasis/fences that models love to wrap tool calls in. */\r\nfunction normalizeToolText(t) {\r\n  return t\r\n    .replace(/[\\u2018\\u2019\\u201B]/g, \"'\")           // curly single quotes\r\n    .replace(/[\\u201C\\u201D\\u201F]/g, '\"')           // curly double quotes\r\n    .replace(/```(?:tool|tools|text|plaintext)?\\s*\\n?(\\s*(?:TOOL:)?(?:say|talk|whisper|chat|ask|assign_task|co_work|complete_task|handoff|spawn_subagent|run_tests|update_answer|plan_ready|start_talk|done)\\s*\\([\\s\\S]*?)```/gi, \"$1\") // unwrap fenced tool-only blocks\r\n    .replace(/\\*\\*\\s*(TOOL:)/gi, \"$1\")               // **TOOL:\r\n    .replace(/(TOOL:\\s*(?:[a-z_]+)\\s*\\([\\s\\S]*?\\))\\s*\\*\\*/gi, \"$1\"); // TOOL:...()**\r\n}\r\n\r\n/* conversational tools — available in BOTH modes */\r\nconst CHAT_TOOLS =\r\n  \"TOOL:chat(message) — talk to the whole team in the group chat; think out loud together\\n\" +\r\n  \"TOOL:talk(message) — post to the shared team board every teammate sees\\n\" +\r\n  \"TOOL:ask(teammate, question) — ask a teammate a direct question RIGHT NOW; they answer immediately and their reply is posted for all\\n\" +\r\n  \"TOOL:whisper(teammate, message) — private note only that teammate sees next\\n\" +\r\n  \"TOOL:say(message) — speak a short note directly to the user\\n\" +\r\n  \"TOOL:assign_task(teammate, task) — put a task on the shared task board owned by that teammate; everyone sees who owns what\\n\" +\r\n  \"TOOL:handoff(teammate, reason) — pass control to exactly who should speak/act next\\n\";\r\n\r\nconst PLAN_GUIDE =\r\n  \"PLANNING TOOLS — chat first, decide together, then build:\\n\" +\r\n  CHAT_TOOLS +\r\n  \"TOOL:plan_ready(one-line summary of the agreed plan) — call ONLY once the whole team has weighed in and the plan (task board) is solid; this ends PLAN mode and starts WORK\\n\";\r\n\r\nconst WORK_GUIDE =\r\n  \"WORKING TOOLS — call any, each on its own line, as many as you need:\\n\" +\r\n  CHAT_TOOLS +\r\n  \"TOOL:co_work(teammate_a, teammate_b, task) — run TWO models on ONE task in parallel right now; both results are posted to the team\\n\" +\r\n  \"TOOL:complete_task(task_id) — mark a task on the board done (id shown like T1, T2)\\n\" +\r\n  \"TOOL:spawn_subagent(task) — spin up a focused subagent now; its result is posted to the team board\\n\" +\r\n  \"TOOL:run_tests() — run real static tests on the current shared answer & files; results are posted for everyone\\n\" +\r\n  \"TOOL:update_answer() — replace the shared answer; put the FULL new answer in a fenced block starting with ```answer on the lines after this call\\n\" +\r\n  \"TOOL:create_file(name.ext) — create/overwrite a downloadable file; full content in a fenced block starting with ```file:name.ext\\n\" +\r\n  \"TOOL:edit_file(name.ext, old_text, new_text) — edit an existing file by replacing old_text with new_text exactly\\n\" +\r\n  \"TOOL:read_file(name.ext) — read the contents of a file you created or need to inspect\\n\" +\r\n  \"TOOL:internet_search(query) — search the internet via DuckDuckGo; results are returned to you directly\\n\" +\r\n  \"TOOL:ask_user(question, option1, option2, ...) — ask the user a question with suggested options; they reply and you continue\\n\" +\r\n  \"TOOL:start_talk(one-line summary) — call ONLY once the work is built, integrated and tests pass; this ends WORK mode and starts TALK, where the team delivers the answer to the user\\n\";\r\n\r\nconst TALK_GUIDE =\r\n  \"TALK TOOLS — the work is built; now talk WITH THE USER and deliver the final answer:\\n\" +\r\n  CHAT_TOOLS +\r\n  \"TOOL:update_answer() — write/refine the FINAL user-facing answer; put the FULL answer in a fenced block starting with ```answer on the lines after this call\\n\" +\r\n  \"TOOL:create_file(name.ext) — create/overwrite a downloadable file; full content in a fenced block starting with ```file:name.ext\\n\" +\r\n  \"TOOL:edit_file(name.ext, old_text, new_text) — edit an existing file by replacing old_text with new_text exactly\\n\" +\r\n  \"TOOL:read_file(name.ext) — read the contents of a file you created or need to inspect\\n\" +\r\n  \"TOOL:internet_search(query) — search the internet via DuckDuckGo; results are returned to you directly\\n\" +\r\n  \"TOOL:ask_user(question, option1, option2, ...) — ask the user a question with suggested options; they reply and you continue\\n\" +\r\n  \"TOOL:done(summary) — end the whole session; call ONLY after the final answer is polished, complete and genuinely ready for the user\\n\";\r\n\r\nconst PERSONA = (self, team, mode) =>\r\n  \"You are \" + shortName(self) + \", one member of 'mizi' — a combined AI agent where models work together like close friends. \" +\r\n  \"Teammates: \" + team.filter(t => t !== self).map(shortName).join(\", \") + \".\\n\" +\r\n  \"mizi runs in THREE modes and the team itself decides when to move between them: PLAN → WORK → TALK. RIGHT NOW the mode is: \" + mode.toUpperCase() + \".\\n\" +\r\n  (mode === \"plan\"\r\n    ? \"PLAN MODE — do NOT build anything yet. Chat with your friends to understand the request, then DIVIDE it into clear parts. \" +\r\n      \"The goal of planning is a task board where every part of the work is a separate task assigned to a specific teammate with TOOL:assign_task(teammate, part) — including yourself. \" +\r\n      \"Make the parts modular and non-overlapping so each friend can build their own part independently and in parallel. Play to each friend's strengths. \" +\r\n      \"Every friend should contribute AND own at least one part before planning ends. When the plan is solid and every part has an owner, YOU decide it's ready — someone calls TOOL:plan_ready(...) to move the team into WORK.\\n\" +\r\n      PLAN_GUIDE\r\n    : mode === \"work\"\r\n    ? \"WORK MODE — the plan is agreed and the team has DIVIDED the work; each teammate's built part is shown under PARTS. \" +\r\n      \"Your job now is to INTEGRATE those parts into one coherent shared answer/files, resolve overlaps and gaps, test and debug each other's work. \" +\r\n      \"When the build is genuinely complete and integrated, YOU decide it's time to talk to the user — someone calls TOOL:start_talk(...) to move the team into TALK.\\n\" +\r\n      WORK_GUIDE\r\n    : \"TALK MODE — the work is built and integrated. Now speak directly WITH THE USER and shape the FINAL answer together: make it clear, complete, well-structured and genuinely helpful. \" +\r\n      \"Use TOOL:update_answer to write/refine the final user-facing answer, TOOL:say to address the user, and chat briefly with each other to agree it's ready. \" +\r\n      \"When the answer is polished and truly ready, YOU decide the session is over — someone calls TOOL:done(...).\\n\" +\r\n      TALK_GUIDE) +\r\n  \"The TASK BOARD below is your shared plan — always check who is working on what.\\n\" +\r\n  \"Rules: keep prose outside tool calls brief (internal thinking shown to the user as your reasoning). \" +\r\n  \"The user only receives the SHARED ANSWER plus created files. \" +\r\n  \"Always end your message by passing control: TOOL:handoff(...)\" + (mode === \"plan\" ? \" or TOOL:plan_ready(...).\" : mode === \"work\" ? \" or TOOL:start_talk(...).\" : \" or TOOL:done(...).\");\r\n\r\nfunction fmtWhispers(model, ws) {\r\n  const w = ws.whispers[model];\r\n  if (!w || !w.length) return \"\";\r\n  const lines = w.map(x => \"- from \" + shortName(x.from) + \": \" + x.msg).join(\"\\n\");\r\n  ws.whispers[model] = [];\r\n  return \"PRIVATE WHISPERS to you:\\n\" + lines + \"\\n\\n\";\r\n}\r\n\r\nfunction fmtTasks(model, ws) {\r\n  const t = ws.tasks[model];\r\n  if (!t || !t.length) return \"\";\r\n  const lines = t.map(x => \"- from \" + shortName(x.from) + \": \" + x.task).join(\"\\n\");\r\n  ws.tasks[model] = [];\r\n  return \"TASKS ASSIGNED TO YOU (act on these now):\\n\" + lines + \"\\n\\n\";\r\n}\r\n\r\nfunction fmtTaskBoard(ws) {\r\n  if (!ws.taskBoard.length) return \"TASK BOARD: (empty — no tasks registered yet)\\n\\n\";\r\n  const lines = ws.taskBoard.map(t =>\r\n    t.id + \" [\" + (t.status === \"done\" ? \"DONE\" : \"OPEN\") + \"] owner(s): \" +\r\n    t.owners.map(shortName).join(\" + \") + \" — \" + t.desc);\r\n  return \"TASK BOARD (who is working on what):\\n\" + lines.join(\"\\n\") + \"\\n\\n\";\r\n}\r\n\r\nfunction fmtParts(ws) {\r\n  const ids = Object.keys(ws.parts);\r\n  if (!ids.length) return \"\";\r\n  const lines = ids.map(id => {\r\n    const p = ws.parts[id];\r\n    return \"▼ \" + id + \" — \" + shortName(p.owner) + \"'s part (\" + p.desc + \"):\\n\" + p.content;\r\n  });\r\n  return \"PARTS BUILT BY THE TEAM (each teammate's own work — integrate these into the shared answer):\\n\" + lines.join(\"\\n\\n\") + \"\\n\\n\";\r\n}\r\n\r\nfunction workspaceView(ws) {\r\n  let s = \"\";\r\n  s += fmtTaskBoard(ws);\r\n  s += fmtParts(ws);\r\n  if (ws.talkBoard.length) s += \"TEAM CHAT (latest):\\n\" + ws.talkBoard.slice(-14).map(t => \"- \" + t).join(\"\\n\") + \"\\n\\n\";\r\n  if (ws.testReport) s += \"LATEST TEST RESULTS:\\n\" + ws.testReport + \"\\n\\n\";\r\n  if (ws.files.size) s += \"FILES CREATED SO FAR: \" + [...ws.files.keys()].join(\", \") + \"\\n\\n\";\r\n  s += ws.answer\r\n    ? \"CURRENT SHARED ANSWER (what the user will receive):\\n<<<ANSWER\\n\" + ws.answer + \"\\nANSWER>>>\\n\"\r\n    : \"CURRENT SHARED ANSWER: (empty — nobody has written it yet)\\n\";\r\n  return s;\r\n}\r\n\r\nfunction runWorkspaceTests(ws, trace) {\r\n  let all = [];\r\n  const ans = ws.answer || \"\";\r\n  all = all.concat(localTest(ans).results);\r\n  for (const [name, content] of ws.files) {\r\n    const ext = (name.split(\".\").pop() || \"\").toLowerCase();\r\n    const fenced = \"```\" + (ext === \"js\" ? \"javascript\" : ext) + \"\\n\" + content + \"\\n```\";\r\n    const res = localTest(fenced).results.map(r => ({ pass: r.pass, msg: name + \": \" + r.msg }));\r\n    all = all.concat(res);\r\n  }\r\n  if (!all.length) all.push({ pass: true, msg: \"no testable code blocks found (nothing to statically check)\" });\r\n  trace.tests(all);\r\n  const fails = all.filter(r => !r.pass);\r\n  ws.testReport = all.map(r => (r.pass ? \"PASS — \" : \"FAIL — \") + r.msg).join(\"\\n\");\r\n  return fails;\r\n}\r\n\r\n/* Line-based, nesting-aware extractor for the special build blocks:\r\n     ```file:name.ext … ```   and   ```answer … ```\r\n   A regex can't do this reliably because file CONTENT often contains its own\r\n   fenced code (```javascript … ```), and the stream may be TRUNCATED before the\r\n   closing fence ever arrives. Both cases made the old non-greedy regex stop early\r\n   and leak the rest of the file into the chat. This scanner instead:\r\n     • closes a block only on a BARE ``` at the current nesting level,\r\n     • treats ```lang lines inside a block as nested opens/closes (kept as content),\r\n     • if a block is never closed (truncation), still saves what we captured,\r\n     • starts a fresh block if a new ```file:/```answer appears before the last closed.\r\n   Models also frequently SPLIT one long file across several fences — a ```file:name\r\n   block followed by loose ```js / ```html blocks that continue the same file. Those\r\n   trailing fences used to leak into the chat as raw code (\"javascript G.tileGrid…\").\r\n   And in WORK mode they often skip ```file: entirely and just dump the whole app in a\r\n   ```html fence. So when opts.codeAsFile is set (WORK mode) every top-level code fence\r\n   is captured as file content — appended to the current file if one exists, otherwise\r\n   a fresh file whose name onBlock infers from the language/content.\r\n   onBlock(kind, name, content, meta) runs per block and RETURNS the resolved file name\r\n   (used to track continuations); returns leftover prose with all blocks removed. */\r\nfunction extractBuildBlocks(text, onBlock, opts) {\r\n  const codeAsFile = !!(opts && opts.codeAsFile);\r\n  const lines = text.split(\"\\n\");\r\n  const isFence = (l) => /^\\s*```/.test(l);\r\n  const fenceInfo = (l) => {\r\n    const after = l.replace(/^\\s*```/, \"\").trim();       // text after the backticks\r\n    if (/^file:/i.test(after)) return { kind: \"file\", name: after.slice(5).trim() };\r\n    if (/^answer\\b/i.test(after)) return { kind: \"answer\", name: \"\" };\r\n    if (after === \"\") return { kind: \"close\" };          // bare ``` — a closing fence\r\n    return { kind: \"open\", lang: after };                // ```lang — inner code fence\r\n  };\r\n  const out = [];\r\n  let block = null;        // { kind, name, buf:[], nested:0, append:bool, lang:str }\r\n  let lastFile = null;     // name of the most recent file, for continuations\r\n  const flush = () => {\r\n    if (!block) return;\r\n    const resolved = onBlock(block.kind, block.name, block.buf.join(\"\\n\").replace(/\\n$/, \"\"), { append: !!block.append, lang: block.lang || \"\" });\r\n    if (block.kind === \"file\" && resolved) lastFile = resolved;\r\n    block = null;\r\n  };\r\n  for (const line of lines) {\r\n    if (!block) {\r\n      if (isFence(line)) {\r\n        const f = fenceInfo(line);\r\n        if (f.kind === \"file\" || f.kind === \"answer\") { block = { kind: f.kind, name: f.name, buf: [], nested: 0 }; continue; }\r\n        // WORK mode: any loose ```lang / bare ``` fence is file content —\r\n        // a continuation of the current file, or a new inferred-name file.\r\n        if (codeAsFile && (f.kind === \"open\" || f.kind === \"close\")) {\r\n          block = lastFile\r\n            ? { kind: \"file\", name: lastFile, buf: [], nested: 0, append: true }\r\n            : { kind: \"file\", name: \"\", buf: [], nested: 0, lang: f.lang || \"\" };\r\n          continue;\r\n        }\r\n        // PLAN mode (or non-file fence): a lone ```lang code fence still needs its\r\n        // closing ``` swallowed so the fence markers don't leak — treat as prose block.\r\n      }\r\n      out.push(line);\r\n      continue;\r\n    }\r\n    // inside a build block\r\n    if (isFence(line)) {\r\n      const f = fenceInfo(line);\r\n      if (f.kind === \"file\" || f.kind === \"answer\") {\r\n        if (block.nested > 0) { block.buf.push(line); continue; } // nested pseudo-block content\r\n        flush();                                                  // new top-level block starts\r\n        block = { kind: f.kind, name: f.name, buf: [], nested: 0 };\r\n        continue;\r\n      }\r\n      if (f.kind === \"open\") { block.nested++; block.buf.push(line); continue; }\r\n      // bare close\r\n      if (block.nested > 0) { block.nested--; block.buf.push(line); continue; }\r\n      flush(); // closes the build block\r\n      continue;\r\n    }\r\n    block.buf.push(line);\r\n  }\r\n  flush(); // save any unterminated (truncated) block instead of leaking it\r\n  return out.join(\"\\n\");\r\n}\r\n\r\n/* Pick a filename for a code block that had no ```file:name — infer from the fence\r\n   language and content, reusing an existing file of that type when one exists. */\r\nfunction inferFileName(lang, content, ws) {\r\n  const l = (lang || \"\").toLowerCase();\r\n  const body = (content || \"\").trim();\r\n  const byExt = (re, fallback) => { for (const n of ws.files.keys()) if (re.test(n)) return n; return fallback; };\r\n  if (l === \"html\" || l === \"htm\" || /^<!doctype html|^<html[\\s>]/i.test(body)) return byExt(/\\.html?$/i, \"index.html\");\r\n  if (l === \"css\") return byExt(/\\.css$/i, \"styles.css\");\r\n  if (l === \"js\" || l === \"javascript\" || l === \"jsx\" || l === \"mjs\") return byExt(/\\.m?jsx?$/i, \"script.js\");\r\n  if (l === \"ts\" || l === \"typescript\") return byExt(/\\.tsx?$/i, \"script.ts\");\r\n  if (l === \"json\") return byExt(/\\.json$/i, \"data.json\");\r\n  if (l) return \"file.\" + l.replace(/[^a-z0-9]/gi, \"\").slice(0, 8);\r\n  // bare fence, unknown type: assume it's the main document for these single-file apps\r\n  return byExt(/\\.html?$/i, \"index.html\");\r\n}\r\n\r\n/* Rescue a raw, UNFENCED HTML document that the model dumped straight into its\r\n   message (no ```). Returns { doc, leftover } or null. */\r\nfunction sweepRawDoc(text) {\r\n  const m = /<!DOCTYPE html|<html[\\s>]/i.exec(text);\r\n  if (!m) return null;\r\n  const start = m.index;\r\n  const tail = text.slice(start);\r\n  const ci = tail.toLowerCase().lastIndexOf(\"</html>\");\r\n  const doc = ci !== -1 ? tail.slice(0, ci + 7) : tail;      // to </html> if present, else EOF\r\n  const after = ci !== -1 ? tail.slice(ci + 7) : \"\";\r\n  if (doc.trim().length < 60) return null;                  // ignore a stray inline <html> mention\r\n  return { doc: doc.trim(), leftover: text.slice(0, start) + after };\r\n}\r\n\r\n/* Parse one agent step: mutate workspace, execute tools, return control decisions.\r\n   mode is \"plan\" (chat & agree the plan, no building) or \"work\" (execute). */\r\nfunction processTurn(model, rawText, trace, ws, mode) {\r\n  let text = normalizeToolText(rawText);\r\n  let updatedAnswer = false;\r\n\r\n  if (mode === \"work\" || mode === \"talk\") {\r\n    /* Capture files (```file:name AND bare ```lang code fences), shared-answer\r\n       updates (```answer), inner fences, continuations, and truncated blocks. */\r\n    const saveFile = (name, content, meta) => {\r\n      // A fresh full HTML document always REPLACES (never appends onto) the file.\r\n      const freshDoc = /^<!doctype html|^<html[\\s>]/i.test(content.trim());\r\n      if (!name) name = inferFileName(meta.lang, content, ws);\r\n      name = name.trim();\r\n      if (!name) return null;\r\n      const existed = ws.files.has(name);\r\n      if (meta.append && existed && !freshDoc) {\r\n        const merged = ws.files.get(name) + \"\\n\" + content;\r\n        ws.files.set(name, merged);\r\n        trace.toolUse(\"create_file\", model, name + \" · +\" + fmtChars(content.length) + \" chars (continued → \" + fmtChars(merged.length) + \")\");\r\n      } else {\r\n        ws.files.set(name, content);\r\n        const lines = (content.match(/\\n/g) || []).length + 1;\r\n        trace.toolUse(\"create_file\", model, name + \" · \" + fmtChars(content.length) + \" chars\" + (existed ? \" (overwritten)\" : \"\"));\r\n        trace.fileActivity(existed ? \"edited\" : \"created\", name, \"+\" + lines, existed ? \"\" : \"\");\r\n        if (!existed) bumpFileCount(1);\r\n      }\r\n      return name;\r\n    };\r\n    text = extractBuildBlocks(text, (kind, name, content, meta) => {\r\n      if (kind === \"file\") return saveFile(name, content, meta);\r\n      if (kind === \"answer\") { ws.answer = content; updatedAnswer = true; }\r\n      return null;\r\n    }, { codeAsFile: true });\r\n    /* Rescue an unfenced HTML document dumped straight into the message. */\r\n    const raw = sweepRawDoc(text);\r\n    if (raw) { saveFile(\"\", raw.doc, { lang: \"html\" }); text = raw.leftover; }\r\n  } else {\r\n    /* PLAN mode: no building allowed — strip any build blocks (fenced or raw) and remind. */\r\n    let tried = false;\r\n    text = extractBuildBlocks(text, () => { tried = true; return null; });\r\n    const raw = sweepRawDoc(text);\r\n    if (raw) { tried = true; text = raw.leftover; }\r\n    if (tried) ws.talkBoard.push(\"SYSTEM: \" + shortName(model) + \" tried to build during PLAN — held back. Agree the plan first, then TOOL:plan_ready.\");\r\n  }\r\n\r\n  /* 3. execute tool calls in order */\r\n  const out = { handoff: null, done: false, doneSummary: \"\", spawns: [], wantsTests: false, asks: [], coworks: [], planReady: false, planSummary: \"\", startTalk: false, startTalkSummary: \"\", toolCount: 0 };\r\n  const secondComma = (s) => { const i = s.indexOf(\",\"); return i === -1 ? -1 : s.indexOf(\",\", i + 1); };\r\n  const unquote = (s) => s.replace(/^\\s*(['\"`])([\\s\\S]*)\\1[\\s.,;:!?]*$/, \"$2\").trim();\r\n  const handleTool = (tool, argstr) => {\r\n    out.toolCount++;\r\n    tool = tool.toLowerCase();\r\n    const args = unquote(argstr.trim());\r\n    const firstComma = args.indexOf(\",\");\r\n    const arg1 = unquote(firstComma === -1 ? args : args.slice(0, firstComma).trim());\r\n    const rest = unquote(firstComma === -1 ? \"\" : args.slice(firstComma + 1).trim());\r\n    const findMate = (raw) => ws.team.find(t => t === raw || shortName(t).toLowerCase() === shortName(raw).toLowerCase()) || null;\r\n\r\n    if (tool === \"say\") {\r\n      trace.chat(model, args, { kind: \"say\" });\r\n      addSayNote(model, args);\r\n    } else if (tool === \"talk\" || tool === \"chat\") {\r\n      trace.chat(model, args, { kind: \"talk\" });\r\n      ws.talkBoard.push(shortName(model) + \": \" + args);\r\n      for (const t of ws.team) if (t !== model) map.pulse(model, t, \"rgba(217,119,87,.7)\");\r\n    } else if (tool === \"whisper\") {\r\n      const target = findMate(arg1);\r\n      trace.chat(model, rest || args, { kind: \"whisper\", to: target || arg1 });\r\n      if (target) {\r\n        (ws.whispers[target] = ws.whispers[target] || []).push({ from: model, msg: rest || args });\r\n        map.pulse(model, target, \"rgba(139,196,141,.8)\");\r\n      } else ws.talkBoard.push(shortName(model) + \" (whisper undelivered): \" + (rest || args));\r\n    } else if (tool === \"ask\") {\r\n      const target = findMate(arg1);\r\n      trace.chat(model, rest || args, { kind: \"ask\", to: target || arg1 });\r\n      if (target) { out.asks.push({ from: model, to: target, question: rest || args }); map.pulse(model, target, \"rgba(139,196,141,.85)\"); }\r\n      else ws.talkBoard.push(shortName(model) + \" asked unknown teammate '\" + arg1 + \"': \" + (rest || args));\r\n    } else if (tool === \"assign_task\") {\r\n      const target = findMate(arg1);\r\n      trace.toolUse(\"assign_task\", model, rest || args, target || arg1);\r\n      if (target) {\r\n        const id = \"T\" + (++ws.taskSeq);\r\n        ws.taskBoard.push({ id, desc: rest || args, owners: [target], status: \"open\" });\r\n        (ws.tasks[target] = ws.tasks[target] || []).push({ from: model, task: (rest || args) + \" (\" + id + \")\" });\r\n        map.pulse(model, target, \"rgba(217,119,87,.9)\");\r\n        if (!out.handoff) out.handoff = target; /* assigning implies they should act soon */\r\n      } else ws.talkBoard.push(shortName(model) + \" tried to assign a task to unknown teammate '\" + arg1 + \"'\");\r\n    } else if (tool === \"co_work\" && mode === \"work\") {\r\n      const sc = secondComma(args);\r\n      const a = findMate(arg1);\r\n      const bRaw = sc === -1 ? \"\" : args.slice(firstComma + 1, sc).trim();\r\n      const b = findMate(bRaw);\r\n      const task = sc === -1 ? rest : args.slice(sc + 1).trim();\r\n      trace.toolUse(\"co_work\", model, (a ? shortName(a) : arg1) + \" + \" + (b ? shortName(b) : bRaw) + \" → \" + task);\r\n      if (a && b && task) {\r\n        const id = \"T\" + (++ws.taskSeq);\r\n        ws.taskBoard.push({ id, desc: task, owners: [a, b], status: \"open\" });\r\n        out.coworks.push({ id, a, b, task });\r\n      } else ws.talkBoard.push(shortName(model) + \" co_work needs two known teammates and a task\");\r\n    } else if (tool === \"complete_task\") {\r\n      const t = ws.taskBoard.find(t => t.id.toLowerCase() === arg1.toLowerCase());\r\n      trace.toolUse(\"complete_task\", model, t ? arg1 + \" marked done\" : \"unknown task \" + arg1);\r\n      if (t) t.status = \"done\";\r\n    } else if (tool === \"handoff\") {\r\n      const target = findMate(arg1);\r\n      trace.toolUse(\"handoff\", model, rest || \"your turn\", target || arg1);\r\n      if (target) { out.handoff = target; map.pulse(model, target, \"rgba(240,238,230,.9)\"); }\r\n    } else if (tool === \"plan_ready\" && mode === \"plan\") {\r\n      trace.toolUse(\"plan_ready\", model, args || \"plan agreed\");\r\n      out.planReady = true;\r\n      out.planSummary = args;\r\n    } else if (tool === \"spawn_subagent\" && mode === \"work\") {\r\n      trace.toolUse(\"spawn_subagent\", model, args);\r\n      out.spawns.push(args);\r\n    } else if (tool === \"run_tests\" && mode === \"work\") {\r\n      trace.toolUse(\"run_tests\", model, \"static checks on shared answer + \" + ws.files.size + \" file(s)\");\r\n      out.wantsTests = true;\r\n    } else if (tool === \"update_answer\" && (mode === \"work\" || mode === \"talk\")) {\r\n      trace.toolUse(\"update_answer\", model, updatedAnswer ? \"shared answer replaced · \" + fmtChars(ws.answer.length) + \" chars\" : \"no ```answer block found — ignored\");\r\n    } else if (tool === \"start_talk\" && mode === \"work\") {\r\n      trace.toolUse(\"start_talk\", model, args || \"moving to talk with the user\");\r\n      out.startTalk = true;\r\n      out.startTalkSummary = args;\r\n    } else if (tool === \"done\") {\r\n      /* models drive the transitions: in WORK, done implies \"ready to talk\";\r\n         in TALK, done truly ends the session. */\r\n      if (mode === \"work\") {\r\n        trace.toolUse(\"start_talk\", model, args || \"moving to talk with the user\");\r\n        out.startTalk = true;\r\n        out.startTalkSummary = args;\r\n      } else if (mode === \"talk\") {\r\n        trace.toolUse(\"done\", model, args || \"task complete\");\r\n        out.done = true;\r\n        out.doneSummary = args;\r\n      } else {\r\n        out.toolCount--;\r\n      }\r\n    } else if (tool === \"edit_file\" && (mode === \"work\" || mode === \"talk\")) {\r\n      /* edit_file(name, old_text, new_text) — find-and-replace in an existing file */\r\n      const secondCommaIdx = args.indexOf(\",\", args.indexOf(\",\") + 1);\r\n      const fileName = unquote(arg1);\r\n      const oldText = secondCommaIdx === -1 ? \"\" : unquote(args.slice(args.indexOf(\",\") + 1, secondCommaIdx).trim());\r\n      const newText = secondCommaIdx === -1 ? \"\" : unquote(args.slice(secondCommaIdx + 1).trim());\r\n      if (ws.files.has(fileName) && oldText && newText) {\r\n        const content = ws.files.get(fileName);\r\n        if (content.includes(oldText)) {\r\n          const updated = content.replace(oldText, newText);\r\n          ws.files.set(fileName, updated);\r\n          const addedLines = (newText.match(/\\n/g) || []).length + 1;\r\n          const removedLines = (oldText.match(/\\n/g) || []).length + 1;\r\n          trace.toolUse(\"edit_file\", model, fileName + \" +\" + addedLines + \" -\" + removedLines);\r\n          trace.fileActivity(\"edited\", fileName, \"+\" + addedLines, \"-\" + removedLines);\r\n          bumpFileCount(0); // no new file, just edited\r\n        } else {\r\n          trace.toolUse(\"edit_file\", model, fileName + \" — old_text not found in file\");\r\n        }\r\n      } else if (!ws.files.has(fileName)) {\r\n        trace.toolUse(\"edit_file\", model, fileName + \" — file not found, use create_file first\");\r\n      } else {\r\n        trace.toolUse(\"edit_file\", model, \"edit_file requires: name, old_text, new_text\");\r\n      }\r\n    } else if (tool === \"read_file\") {\r\n      /* read_file(name) — read a file's contents */\r\n      const fileName = unquote(arg1);\r\n      if (ws.files.has(fileName)) {\r\n        const content = ws.files.get(fileName);\r\n        trace.toolUse(\"read_file\", model, fileName + \" · \" + fmtChars(content.length) + \" chars\");\r\n        /* Feed the file content back into the workspace so the model can see it */\r\n        ws.talkBoard.push(shortName(model) + \" read \" + fileName + \" (\" + fmtChars(content.length) + \" chars): \" + content.slice(0, 600));\r\n      } else {\r\n        trace.toolUse(\"read_file\", model, fileName + \" — file not found\");\r\n      }\r\n    } else if (tool === \"internet_search\") {\r\n      /* internet_search(query) — search DuckDuckGo from the browser */\r\n      trace.toolUse(\"internet_search\", model, \"searching: \" + args);\r\n      out.searches = out.searches || [];\r\n      out.searches.push({ model, query: args });\r\n    } else if (tool === \"ask_user\") {\r\n      /* ask_user(question, option1, option2, ...) — ask the user a question */\r\n      trace.toolUse(\"ask_user\", model, args);\r\n      out.userQuestions = out.userQuestions || [];\r\n      out.userQuestions.push({ model, question: arg1, options: rest ? rest.split(\",\").map(s => s.trim()) : [] });\r\n    } else {\r\n      out.toolCount--; /* recognized name but not valid in this mode — not a real call */\r\n    }\r\n    return \"\";\r\n  };\r\n\r\n  /* Extract every tool call with a balanced-paren scan, execute it, and splice it\r\n     out of the text so only real prose is left behind. Primary pass looks for the\r\n     \"TOOL:\" prefix anywhere; fallback pass accepts a bare name() at line start. */\r\n  const parseTools = (src, startRe, allowNoParen) => {\r\n    startRe.lastIndex = 0;\r\n    const cuts = []; // [start, end) spans to remove, in order\r\n    let m;\r\n    while ((m = startRe.exec(src)) !== null) {\r\n      const tool = m[1];\r\n      // Cut from the \"TOOL:\" prefix (primary) or decoration (bare), but keep a\r\n      // leading newline so surrounding prose lines stay separated.\r\n      const nameStart = src[m.index] === \"\\n\" ? m.index + 1 : m.index;\r\n      let i = startRe.lastIndex;                 // just past the tool name\r\n      while (i < src.length && (src[i] === \" \" || src[i] === \"\\t\")) i++;\r\n      let argstr, spanEnd;\r\n      if (src[i] === \"(\") {\r\n        // normal \"(...)\" args — balanced-scan, tolerant of nesting/missing \")\"\r\n        const { end, closed } = scanArgsEnd(src, i);\r\n        argstr = src.slice(i + 1, end);\r\n        spanEnd = closed ? end + 1 : end;\r\n      } else if (allowNoParen) {\r\n        // model dropped the parens — take the remainder of this line as the arg\r\n        let nl = src.indexOf(\"\\n\", startRe.lastIndex);\r\n        if (nl === -1) nl = src.length;\r\n        argstr = src.slice(startRe.lastIndex, nl);\r\n        spanEnd = nl;\r\n      } else {\r\n        continue; // bare pass requires parens — this match isn't a real call\r\n      }\r\n      handleTool(tool, argstr);\r\n      cuts.push([nameStart, spanEnd]);\r\n      startRe.lastIndex = spanEnd;                // never rescan inside consumed args\r\n    }\r\n    if (!cuts.length) return src;\r\n    let outStr = \"\", prev = 0;\r\n    for (const [s, e] of cuts) { outStr += src.slice(prev, s); prev = e; }\r\n    return outStr + src.slice(prev);\r\n  };\r\n\r\n  text = parseTools(text, TOOL_START_RE, true);\r\n  if (out.toolCount === 0) text = parseTools(text, BARE_START_RE, false);\r\n\r\n  /* leftover prose = the model's visible thinking — shown in full, collapsed */\r\n  const prose = text.replace(/^SPAWN_SUBAGENT:.*$/gim, \"\").trim();\r\n  if (prose) trace.think(prose);\r\n\r\n  /* SAFETY NET: model called nothing usable. Don't stall — treat the whole message\r\n     as a chat contribution so the conversation keeps flowing, then auto-handoff. */\r\n  if (out.toolCount === 0) {\r\n    const msg = prose || rawText.trim();\r\n    if (msg) {\r\n      trace.chat(model, msg, { kind: \"talk\" }); // show every word\r\n      ws.talkBoard.push(shortName(model) + \": \" + msg.slice(0, 500)); // context memory stays trimmed\r\n    }\r\n    ws.talkBoard.push(\"SYSTEM: \" + shortName(model) + \" didn't call a tool. Reminder — put tool calls on their own line, e.g. TOOL:chat(your message) or TOOL:handoff(teammate, reason).\");\r\n  }\r\n  return out;\r\n}\r\n\r\n/* ---------------- The agent loop ---------------- */\r\n\r\nasync function run() {\r\n  const prompt = els.input.value.trim();\r\n  if (!prompt || state.busy || !state.selected.size) return;\r\n  state.busy = true;\r\n  state.stopped = false;\r\n  els.input.value = \"\"; els.input.style.height = \"auto\";\r\n  updateSendState();\r\n  if (!state.chatting) enterMode(true);\r\n\r\n  /* Show stop button, hide send button */\r\n  const stopBtn = $(\"stopAgentBtn\");\r\n  if (stopBtn) { stopBtn.style.display = \"grid\"; stopBtn.onclick = () => { state.stopped = true; }; }\r\n\r\n  const team = [...state.selected];\r\n  map.setTeam(team);\r\n  addUserMsg(prompt);\r\n  state.history.push({ role: \"user\", content: prompt });\r\n  const memory = state.history.slice(-8, -1);\r\n\r\n  const trace = addTrace();\r\n\r\n  /* shared workspace — the team's world */\r\n  const ws = {\r\n    team,\r\n    answer: \"\",\r\n    files: new Map(),\r\n    talkBoard: [],\r\n    whispers: {},\r\n    tasks: {},\r\n    taskBoard: [],\r\n    taskSeq: 0,\r\n    testReport: \"\",\r\n    parts: {}, /* taskId -> { owner, desc, content } — each teammate's own built part */\r\n    searchResults: {}, /* query -> results from DuckDuckGo */\r\n    userAnswers: {}, /* questionId -> answer from user */\r\n  };\r\n\r\n  let subCount = 0, doneBy = null, doneSummary = \"\", planSummary = \"\";\r\n  let current = team[0];\r\n  const spoke = new Set();\r\n\r\n  /* ---- model-failure recovery: recommend a free model NOT used in this task ---- */\r\n  const failedThisRun = new Set();   // models that errored during this run\r\n  const recommendedIn = new Set();   // candidates we've already suggested (avoid dupes)\r\n  function recommendSwap(failedModel, reason) {\r\n    if (!failedModel) return;\r\n    failedThisRun.add(failedModel);\r\n    /* only recommend once per failed model */\r\n    if (recommendedIn.has(\"for:\" + failedModel)) return;\r\n    /* a candidate is a free model that is NOT selected (not used in this task),\r\n       hasn't failed this run, and hasn't already been recommended */\r\n    const candidate = state.models.find(m =>\r\n      !state.selected.has(m.id) &&\r\n      !failedThisRun.has(m.id) &&\r\n      !recommendedIn.has(m.id)\r\n    );\r\n    if (!candidate) return; // no unused model left to suggest\r\n    recommendedIn.add(\"for:\" + failedModel);\r\n    recommendedIn.add(candidate.id);\r\n    trace.recommend(failedModel, candidate.id, reason, () => {\r\n      /* apply for the user's next run: drop the failed model, add the fresh one */\r\n      state.selected.delete(failedModel);\r\n      state.selected.add(candidate.id);\r\n      renderModelList();\r\n      map.setTeam([...state.selected]);\r\n      updateSendState();\r\n    });\r\n  }\r\n\r\n  trace.setTeam(team);\r\n  trace.thought(\"Mode: \" + state.mode.toUpperCase() + \" · The team is live. They move through three modes on their own: PLAN (agree the approach), WORK (build & integrate), then TALK (deliver the answer to you). No fixed turns — the models decide every handoff and every mode switch themselves.\");\r\n\r\n  /* side-effects shared by both modes (asks always; build effects only in WORK) */\r\n  async function executeSideEffects(r, actor, mode) {\r\n    /* direct questions between models — real API calls, work in BOTH modes */\r\n    if (r.asks.length) {\r\n      setStatus(shortName(actor) + \" is asking teammates…\", true);\r\n      const asks = r.asks.slice(0, 3);\r\n      const qCards = asks.map(a => trace.call(shortName(a.from) + \" asks \" + shortName(a.to), a.to, \"chat\"));\r\n      const answers = await chatAllSettled(asks.map((a, i) => ({\r\n        model: a.to,\r\n        messages: [\r\n          { role: \"system\", content: PERSONA(a.to, team, mode) + \" A teammate is asking you a direct question. Answer it directly and helpfully in a few sentences — no tool calls, just your answer.\" },\r\n          { role: \"user\", content: shortName(a.from) + \" asks you: \" + a.question + \"\\n\\n\" + workspaceView(ws) },\r\n        ],\r\n        opts: { phase: \"ask\", maxContinues: 1, onUpdate: (c, rr) => qCards[i].update(c, rr) },\r\n      })));\r\n      answers.forEach((res, i) => {\r\n        const a = asks[i];\r\n        if (res.ok) {\r\n          qCards[i].ok(res.text); qCards[i].collapse();\r\n          trace.chat(a.to, res.text, { kind: \"answer\", to: a.from });\r\n          ws.talkBoard.push(shortName(a.to) + \" → \" + shortName(a.from) + \" (answer): \" + res.text.slice(0, 500));\r\n          (ws.whispers[a.from] = ws.whispers[a.from] || []).push({ from: a.to, msg: \"Answer to your question \\\"\" + a.question.slice(0, 80) + \"\\\": \" + res.text });\r\n          map.pulse(a.to, a.from, \"rgba(139,196,141,.85)\");\r\n        } else {\r\n          qCards[i].fail(res.error);\r\n          ws.talkBoard.push(shortName(a.to) + \" couldn't answer \" + shortName(a.from) + \": \" + res.error);\r\n          recommendSwap(a.to, String(res.error).slice(0, 80));\r\n        }\r\n      });\r\n    }\r\n    if (mode !== \"work\") return;\r\n\r\n    /* spawned subagents (parallel) */\r\n    if (r.spawns.length) {\r\n      const capped = r.spawns.slice(0, 3);\r\n      setStatus(capped.length + \" subagent(s) running…\", true);\r\n      const jobs = capped.map((task, i) => {\r\n        const subId = \"sub\" + (subCount + i);\r\n        map.addSub(subId, \"sub·\" + (subCount + i + 1));\r\n        const sCard = trace.call(\"Subagent: \" + task.slice(0, 60), actor, \"spin\");\r\n        return { task, mapId: subId, card: sCard };\r\n      });\r\n      subCount += capped.length;\r\n      const results = await chatAllSettled(jobs.map(j => ({\r\n        model: actor,\r\n        messages: [\r\n          { role: \"system\", content: \"You are a focused subagent inside mizi, deployed by \" + shortName(actor) + \". Complete ONLY this subtask, concisely and completely.\" },\r\n          { role: \"user\", content: j.task },\r\n        ],\r\n        opts: { phase: \"subagent\", mapId: j.mapId, onUpdate: (c, rr) => j.card.update(c, rr) },\r\n      })));\r\n      results.forEach((res, i) => {\r\n        if (res.ok) { jobs[i].card.ok(res.text); jobs[i].card.collapse(); ws.talkBoard.push(\"subagent result (\" + jobs[i].task.slice(0, 60) + \"): \" + res.text.slice(0, 500)); }\r\n        else { jobs[i].card.fail(res.error); ws.talkBoard.push(\"subagent FAILED (\" + jobs[i].task.slice(0, 50) + \"): \" + res.error); }\r\n      });\r\n    }\r\n\r\n    /* co_work: two models on one task in parallel */\r\n    if (r.coworks.length) {\r\n      for (const cw of r.coworks) {\r\n        setStatus(shortName(cw.a) + \" + \" + shortName(cw.b) + \" pairing on \" + cw.id + \"…\", true);\r\n        const pair = [cw.a, cw.b];\r\n        const cwCards = pair.map(m => trace.call(\"Co-working \" + cw.id + \": \" + cw.task.slice(0, 44), m, \"code\"));\r\n        pair.forEach(m => map.pulse(actor, m, \"rgba(217,119,87,.9)\"));\r\n        const results = await chatAllSettled(pair.map((m, i) => ({\r\n          model: m,\r\n          messages: [\r\n            { role: \"system\", content: PERSONA(m, team, \"work\") + \" You are pairing with \" + shortName(pair[1 - i]) + \" on the SAME task simultaneously. Do the task fully and well; your partner is doing it too so the team can compare and merge the best of both. Output your complete work — no tool calls.\" },\r\n            { role: \"user\", content: \"Shared task \" + cw.id + \": \" + cw.task + \"\\n\\nUser request for context: \" + prompt + \"\\n\\n\" + workspaceView(ws) },\r\n          ],\r\n          opts: { phase: \"co_work\", onUpdate: (c, rr) => cwCards[i].update(c, rr) },\r\n        })));\r\n        results.forEach((res, i) => {\r\n          if (res.ok) { cwCards[i].ok(res.text); cwCards[i].collapse(); ws.talkBoard.push(shortName(pair[i]) + \" (co_work \" + cw.id + \"): \" + res.text.slice(0, 400)); }\r\n          else { cwCards[i].fail(res.error); ws.talkBoard.push(shortName(pair[i]) + \" failed co_work \" + cw.id + \": \" + res.error); recommendSwap(pair[i], String(res.error).slice(0, 80)); }\r\n        });\r\n        const tb = ws.taskBoard.find(t => t.id === cw.id);\r\n        if (tb) tb.status = \"done\";\r\n      }\r\n    }\r\n\r\n    /* requested tests */\r\n    if (r.wantsTests) {\r\n      const fails = runWorkspaceTests(ws, trace);\r\n      ws.talkBoard.push(shortName(actor) + \" ran tests: \" + (fails.length ? fails.length + \" failure(s) — see test results\" : \"all passing\"));\r\n    }\r\n\r\n    /* internet search via DuckDuckGo */\r\n    if (r.searches && r.searches.length) {\r\n      for (const s of r.searches.slice(0, 3)) {\r\n        try {\r\n          const ddgUrl = \"https://api.duckduckgo.com/?q=\" + encodeURIComponent(s.query) + \"&format=json&no_html=1&skip_disambig=1\";\r\n          const resp = await fetch(ddgUrl);\r\n          const data = await resp.json();\r\n          let resultText = \"\";\r\n          if (data.AbstractText) resultText = data.AbstractText;\r\n          else if (data.RelatedTopics && data.RelatedTopics.length) {\r\n            resultText = data.RelatedTopics.slice(0, 5).map(t => t.Text || t.FirstURL || \"\").filter(Boolean).join(\"\\n\");\r\n          }\r\n          if (!resultText) resultText = \"No results found for: \" + s.query;\r\n          trace.searchResults(s.query, resultText.slice(0, 800));\r\n          ws.talkBoard.push(\"SEARCH (\" + s.query + \"): \" + resultText.slice(0, 500));\r\n          ws.searchResults[s.query] = resultText;\r\n        } catch (e) {\r\n          trace.searchResults(s.query, \"Search failed: \" + (e.message || e));\r\n        }\r\n      }\r\n    }\r\n\r\n    /* user questions — ask the user and wait for their reply */\r\n    if (r.userQuestions && r.userQuestions.length) {\r\n      for (const q of r.userQuestions.slice(0, 2)) {\r\n        const answer = await new Promise(resolve => {\r\n          trace.userQuestion(q.model, q.question, q.options, resolve);\r\n        });\r\n        ws.talkBoard.push(shortName(q.model) + \" asked user: \" + q.question + \" → \" + answer);\r\n        ws.userAnswers[q.question] = answer;\r\n        /* Feed the answer back as a whisper so the next model sees it */\r\n        for (const t of ws.team) {\r\n          (ws.whispers[t] = ws.whispers[t] || []).push({ from: \"__user__\", msg: \"User answered \\\"\" + q.question + \"\\\": \" + answer });\r\n        }\r\n      }\r\n    }\r\n  }\r\n\r\n  /* ---- Real-time tool detection: scans streaming text for TOOL: calls ---- */\r\n  const RT_TOOL_RE = /(?:TOOL:)?(say|talk|whisper|chat|ask|create_file|edit_file|read_file|internet_search|ask_user|assign_task|co_work|complete_task|handoff|spawn_subagent|run_tests|update_answer|plan_ready|start_talk|done)\\s*\\(([^)]{0,200})/gi;\r\n  let _rtEl = null;\r\n  let _rtLastTool = \"\";\r\n  function rtDetect(text, traceFeed) {\r\n    /* Find the LAST incomplete tool call in the text (the one being typed right now) */\r\n    const matches = [...text.matchAll(/(?:TOOL:)?(say|talk|whisper|chat|ask|create_file|edit_file|read_file|internet_search|ask_user|assign_task|co_work|complete_task|handoff|spawn_subagent|run_tests|update_answer|plan_ready|start_talk|done)\\s*\\(([^)]{0,300})$/gi)];\r\n    if (!matches.length) {\r\n      /* Check for a tool name at the end without parens yet (model is typing the name) */\r\n      const nameOnly = [...text.matchAll(/(?:TOOL:)?(say|talk|whisper|chat|ask|create_file|edit_file|read_file|internet_search|ask_user|assign_task|co_work|complete_task|handoff|spawn_subagent|run_tests|update_answer|plan_ready|start_talk|done)\\s*$/gi)];\r\n      if (nameOnly.length && !text.includes(nameOnly[0][0] + \"(\")) {\r\n        const toolName = nameOnly[0][1];\r\n        if (!_rtEl) _rtEl = traceFeed.querySelector(\".rt-tool\");\r\n        if (!_rtEl) {\r\n          _rtEl = document.createElement(\"div\");\r\n          _rtEl.className = \"rt-tool\";\r\n          traceFeed.appendChild(_rtEl);\r\n        }\r\n        _rtEl.innerHTML =\r\n          '<span class=\"rt-ico\">' + (ICONS[toolName] || ICONS.spin) + '</span>' +\r\n          '<span class=\"rt-name\">' + toolName + '</span>' +\r\n          '<span class=\"rt-shimmer\"></span>';\r\n        _rtLastTool = toolName;\r\n        return;\r\n      }\r\n      /* No tool call in progress — remove indicator */\r\n      if (_rtEl) { _rtEl.remove(); _rtEl = null; _rtLastTool = \"\"; }\r\n      return;\r\n    }\r\n    const m = matches[matches.length - 1];\r\n    const toolName = m[1];\r\n    const args = m[2].trim();\r\n    const iconKey = toolName === \"create_file\" ? \"createFile\" : toolName === \"edit_file\" ? \"editFile\" : toolName === \"read_file\" ? \"readFile\" : toolName === \"internet_search\" ? \"internet\" : toolName === \"ask_user\" ? \"askUser\" : toolName === \"handoff\" ? \"handoff\" : toolName === \"done\" ? \"done\" : toolName === \"spawn_subagent\" ? \"subagent\" : toolName === \"subagent\" ? \"subagent\" : toolName;\r\n    if (!_rtEl) _rtEl = traceFeed.querySelector(\".rt-tool\");\r\n    if (!_rtEl) {\r\n      _rtEl = document.createElement(\"div\");\r\n      _rtEl.className = \"rt-tool\";\r\n      traceFeed.appendChild(_rtEl);\r\n    }\r\n    _rtEl.innerHTML =\r\n      '<span class=\"rt-ico\">' + (ICONS[iconKey] || ICONS.spin) + '</span>' +\r\n      '<span class=\"rt-name\">' + toolName + '</span>' +\r\n      '<span class=\"rt-args\">' + esc(args.slice(0, 200)) + '</span>' +\r\n      '<span class=\"rt-shimmer\"></span>';\r\n    _rtLastTool = toolName;\r\n  }\r\n  function rtClear() {\r\n    if (_rtEl) { _rtEl.remove(); _rtEl = null; _rtLastTool = \"\"; }\r\n  }\r\n\r\n  /* run one model's contribution; returns processTurn result (or null on error) */\r\n  async function speak(mode) {\r\n    const everyone = spoke.size >= team.length;\r\n    const sys = PERSONA(current, team, mode) +\r\n      (mode === \"plan\"\r\n        ? (everyone ? \"\\nEveryone has weighed in — if the plan is solid, call TOOL:plan_ready(...).\" : \"\\nNot everyone has spoken yet; make sure every friend contributes before planning ends.\")\r\n        : \"\");\r\n    const userMsg =\r\n      fmtWhispers(current, ws) + fmtTasks(current, ws) +\r\n      \"USER REQUEST:\\n\" + prompt + \"\\n\\n\" + workspaceView(ws) +\r\n      (mode === \"plan\" ? \"\\nYou're in PLAN mode — chat with your friends and help shape the plan now.\"\r\n       : mode === \"work\" ? \"\\nYou're in WORK mode — execute the plan now, and call TOOL:start_talk when the build is done.\"\r\n       : \"\\nYou're in TALK mode — deliver the final answer to the user with TOOL:update_answer, and call TOOL:done when it's ready.\");\r\n    const phaseLabel = mode === \"plan\" ? \" · planning\" : mode === \"work\" ? \" · working\" : \" · talking\";\r\n    const phaseIcon = mode === \"plan\" ? \"brain\" : mode === \"work\" ? \"code\" : \"chat\";\r\n    const card = trace.call(shortName(current) + phaseLabel, current, phaseIcon);\r\n    let outText = \"\";\r\n    try {\r\n      outText = await chat(current, [{ role: \"system\", content: sys }, ...memory, { role: \"user\", content: userMsg }],\r\n        { phase: mode, onUpdate: (c, rr) => {\r\n          card.update(c, rr);\r\n          rtDetect(c, card.el.querySelector(\".trace-feed\"));\r\n        }});\r\n      rtClear();\r\n      card.ok(outText); card.collapse();\r\n    } catch (e) {\r\n      card.fail(String(e.message || e));\r\n      ws.talkBoard.push(shortName(current) + \" errored: \" + String(e.message || e).slice(0, 140));\r\n      recommendSwap(current, String(e.message || e).slice(0, 80));\r\n      return null;\r\n    }\r\n    return processTurn(current, outText, trace, ws, mode);\r\n  }\r\n\r\n  try {\r\n    /* ============================= PLAN ============================= */\r\n    trace.mode(\"plan\", \"◆ PLAN · the team chats to agree the approach\");\r\n    setStatus(\"planning together…\", true);\r\n    let planSteps = 0;\r\n    while (planSteps < MODES[state.mode].planSteps) {\r\n      if (state.stopped) { trace.banner('<span class=\"fail\">⛔ Agent stopped by user</span>'); break; }\r\n      planSteps++;\r\n      setStatus(shortName(current) + \" is planning…\", true);\r\n      const r = await speak(\"plan\");\r\n      if (!r) { current = team[(team.indexOf(current) + 1) % team.length]; continue; }\r\n      spoke.add(current);\r\n      await executeSideEffects(r, current, \"plan\");\r\n\r\n      if (r.planReady) {\r\n        if (spoke.size >= team.length) { planSummary = r.planSummary || \"\"; break; }\r\n        ws.talkBoard.push(\"SYSTEM: plan_ready held — not everyone has contributed yet. \" + team.filter(t => !spoke.has(t)).map(shortName).join(\", \") + \" still need to weigh in.\");\r\n      }\r\n      /* next speaker: model's choice, else someone who hasn't spoken, else round-robin */\r\n      if (r.handoff) current = r.handoff;\r\n      else current = team.find(t => !spoke.has(t)) || team[(team.indexOf(current) + 1) % team.length];\r\n      map.reset();\r\n    }\r\n    trace.mode(\"plan\", \"✓ PLAN ready\" + (planSummary ? \" · \" + planSummary : \"\"));\r\n    ws.talkBoard.push(\"SYSTEM: PLAN complete — switching to WORK mode. Agreed plan: \" + (planSummary || \"(see task board)\"));\r\n\r\n    /* ===================== DIVIDE & BUILD (parallel) ===================== */\r\n    /* Each open task on the board is executed by ITS OWNER — everyone builds\r\n       their own assigned part at the same time, then the team integrates. */\r\n    const openTasks = ws.taskBoard.filter(t => t.status !== \"done\" && t.owners.length);\r\n    if (openTasks.length) {\r\n      trace.mode(\"work\", \"▚ DIVIDE · each teammate builds their assigned part in parallel\");\r\n      /* one job per (task, owner) so a task with two owners is split too */\r\n      const jobs = [];\r\n      openTasks.forEach(t => t.owners.forEach(owner => {\r\n        jobs.push({ task: t, owner });\r\n      }));\r\n      const cards = jobs.map(j => trace.call(shortName(j.owner) + \" builds \" + j.task.id + \": \" + j.task.desc.slice(0, 44), j.owner, \"code\"));\r\n      jobs.forEach(j => { map.pulse(\"__hub\", j.owner, \"rgba(217,119,87,.9)\"); ws.talkBoard.push(shortName(j.owner) + \" starts \" + j.task.id + \": \" + j.task.desc.slice(0, 60)); });\r\n      setStatus(jobs.length + \" teammates building their parts in parallel…\", true);\r\n\r\n      const results = await chatAllSettled(jobs.map((j, i) => ({\r\n        model: j.owner,\r\n        messages: [\r\n          { role: \"system\", content: PERSONA(j.owner, team, \"work\") +\r\n            \" The team has DIVIDED the work. This is YOUR assigned part — build it fully and completely on your own now. \" +\r\n            \"Output only your part's finished work (code and/or content). No tool calls, no planning — just deliver your part so the team can integrate it.\" },\r\n          { role: \"user\", content:\r\n            \"USER REQUEST (for context):\\n\" + prompt + \"\\n\\n\" +\r\n            fmtTaskBoard(ws) +\r\n            \"YOUR ASSIGNED PART — \" + j.task.id + \": \" + j.task.desc + \"\\n\\n\" +\r\n            \"Build this part completely. If you produce a file, wrap it in ```file:name.ext … ```.\" },\r\n        ],\r\n        opts: { phase: \"build \" + j.task.id, onUpdate: (c, r) => { cards[i].update(c, r); rtDetect(c, cards[i].el.querySelector(\".trace-feed\")); } },\r\n      })));\r\n\r\n      results.forEach((res, i) => {\r\n        const j = jobs[i];\r\n        if (res.ok) {\r\n          cards[i].ok(res.text); cards[i].collapse();\r\n          /* capture any files the part produced */\r\n          res.text.replace(/```file:([^\\n`]+)\\n([\\s\\S]*?)```/g, (_, name, content) => {\r\n            name = name.trim();\r\n            if (!ws.files.has(name)) bumpFileCount(1);\r\n            ws.files.set(name, content.replace(/\\n$/, \"\"));\r\n            trace.toolUse(\"create_file\", j.owner, name + \" · \" + fmtChars(content.length) + \" chars\");\r\n            return \"\";\r\n          });\r\n          ws.parts[j.task.id] = { owner: j.owner, desc: j.task.desc, content: res.text.trim() };\r\n          j.task.status = \"done\";\r\n          trace.chat(j.owner, \"Finished my part (\" + j.task.id + \"): \" + j.task.desc, { kind: \"talk\" });\r\n          ws.talkBoard.push(shortName(j.owner) + \" finished \" + j.task.id + \" · \" + fmtChars(res.text.length) + \" chars\");\r\n        } else {\r\n          cards[i].fail(res.error);\r\n          ws.talkBoard.push(shortName(j.owner) + \" failed part \" + j.task.id + \": \" + res.error);\r\n          recommendSwap(j.owner, String(res.error).slice(0, 80));\r\n        }\r\n      });\r\n      map.reset();\r\n      trace.mode(\"work\", \"✓ parts built · \" + Object.keys(ws.parts).length + \" of \" + jobs.length + \" done — now integrating\");\r\n      ws.talkBoard.push(\"SYSTEM: All parts are built (see PARTS above). Now INTEGRATE them into one coherent shared answer, resolve overlaps, test, and finish.\");\r\n    }\r\n\r\n    /* ============================= WORK (integrate) ============================= */\r\n    trace.mode(\"work\", \"● WORK · the team integrates the parts and finishes\");\r\n    /* start integration with whoever built a part, else the planner who closed the plan */\r\n    const partOwners = Object.values(ws.parts).map(p => p.owner);\r\n    if (partOwners.length) current = partOwners[0];\r\n    let workSteps = 0;\r\n    while (workSteps < MODES[state.mode].workSteps) {\r\n      if (state.stopped) { trace.banner('<span class=\"fail\">⛔ Agent stopped by user</span>'); break; }\r\n      workSteps++;\r\n      setStatus(shortName(current) + \" is working…\", true);\r\n      const r = await speak(\"work\");\r\n      if (!r) { current = team[(team.indexOf(current) + 1) % team.length]; continue; }\r\n      await executeSideEffects(r, current, \"work\");\r\n\r\n      /* models decide when the build is ready → move to TALK (gated on tests) */\r\n      if (r.startTalk) {\r\n        const fails = runWorkspaceTests(ws, trace);\r\n        if (fails.length && workSteps < MODES[state.mode].workSteps) {\r\n          trace.banner('<span class=\"fail\">start_talk held — ' + fails.length + \" static test failure(s) still present</span>\");\r\n          ws.talkBoard.push(\"SYSTEM: start_talk() held — fix these first:\\n\" + fails.map(f => f.msg).join(\"; \"));\r\n          current = r.handoff && r.handoff !== current ? r.handoff : team[(team.indexOf(current) + 1) % team.length];\r\n          continue;\r\n        }\r\n        trace.banner('<span class=\"pass\">✓ ' + shortName(current) + \" says the build is ready — moving to talk</span>\");\r\n        break;\r\n      }\r\n      if (r.handoff) current = r.handoff;\r\n      else {\r\n        const withTasks = team.find(t => (ws.tasks[t] || []).length);\r\n        current = withTasks || team[(team.indexOf(current) + 1) % team.length];\r\n      }\r\n      map.reset();\r\n    }\r\n\r\n    /* ============================= TALK ============================= */\r\n    /* The team now decides, on its own, to deliver the answer to the user. */\r\n    trace.mode(\"talk\", \"◗ TALK · the team delivers the answer to the user\");\r\n    ws.talkBoard.push(\"SYSTEM: WORK complete — switching to TALK mode. Compose and deliver the final answer to the user, then TOOL:done.\");\r\n    setStatus(\"talking with you…\", true);\r\n    let talkSteps = 0;\r\n    while (talkSteps < MODES[state.mode].talkSteps) {\r\n      if (state.stopped) { trace.banner('<span class=\"fail\">⛔ Agent stopped by user</span>'); break; }\r\n      talkSteps++;\r\n      setStatus(shortName(current) + \" is talking…\", true);\r\n      const r = await speak(\"talk\");\r\n      if (!r) { current = team[(team.indexOf(current) + 1) % team.length]; continue; }\r\n      await executeSideEffects(r, current, \"talk\");\r\n\r\n      if (r.done) {\r\n        doneBy = current; doneSummary = r.doneSummary;\r\n        trace.banner('<span class=\"pass\">✓ ' + shortName(current) + \" declared the task complete</span>\");\r\n        break;\r\n      }\r\n      if (r.handoff) current = r.handoff;\r\n      else current = team[(team.indexOf(current) + 1) % team.length];\r\n      map.reset();\r\n    }\r\n\r\n    if (!doneBy) trace.banner('<span class=\"fail\">talk step limit reached — delivering the current shared answer</span>');\r\n\r\n    /* deliver: shared answer + files (no extra synthesis pass — what the team wrote is what ships) */\r\n    let deliver = ws.answer.trim();\r\n    if (!deliver) deliver = doneSummary || \"The team ended the session without writing a shared answer. Check the trace above for their work.\";\r\n    const { clean, files: inlineFiles } = extractFiles(deliver);\r\n    for (const f of inlineFiles) if (!ws.files.has(f.name)) { ws.files.set(f.name, f.content); bumpFileCount(1); }\r\n    const allFiles = [...ws.files].map(([name, content]) => ({ name, content }));\r\n\r\n    trace.finish(team.length + \" models · planned & built together\" +\r\n      (doneBy ? \" · completed by \" + shortName(doneBy) : \"\") +\r\n      (allFiles.length ? \" · \" + allFiles.length + \" file(s)\" : \"\"));\r\n    addMiziMsg(renderMd(clean), allFiles);\r\n    state.history.push({ role: \"assistant\", content: clean });\r\n    setStatus(\"done\");\r\n    map.reset();\r\n  } catch (err) {\r\n    trace.finish(\"failed — expand for details\");\r\n    trace.reopen();\r\n    addMiziMsg('<span style=\"color:var(--danger)\">' + esc(\"mizi hit a wall: \" + (err.message || err)) + \"</span>\", []);\r\n    setStatus(\"error\");\r\n  } finally {\r\n    state.busy = false;\r\n    state.stopped = false;\r\n    setLive(state.activeCalls > 0);\r\n    updateSendState();\r\n    /* Hide stop button */\r\n    const stopBtn = $(\"stopAgentBtn\");\r\n    if (stopBtn) stopBtn.style.display = \"none\";\r\n  }\r\n}\r\n\r\n/* ============================================================\r\n   Preview panel — shows file code, live preview, and terminal\r\n   ============================================================ */\r\nfunction openPreview(name, content) {\r\n  const panel = $(\"previewPanel\");\r\n  const title = $(\"ppTitle\");\r\n  const code = $(\"ppCode\");\r\n  const frame = $(\"ppFrame\");\r\n  const term = $(\"ppTerm\");\r\n  title.textContent = name;\r\n  code.textContent = content;\r\n  /* Auto-detect HTML files for live preview */\r\n  const isHtml = /\\.html?$/i.test(name) || /^\\s*<!DOCTYPE html/i.test(content);\r\n  if (isHtml) {\r\n    frame.srcdoc = content;\r\n  } else {\r\n    frame.srcdoc = \"<pre style='font-family:monospace;padding:16px;color:#ccc;background:#1a1918'>\" + esc(content) + \"</pre>\";\r\n  }\r\n  /* Show code tab by default */\r\n  document.querySelectorAll(\".pp-tab\").forEach(t => t.classList.remove(\"active\"));\r\n  document.querySelector('.pp-tab[data-tab=\"code\"]').classList.add(\"active\");\r\n  code.style.display = \"\";\r\n  frame.style.display = \"none\";\r\n  term.style.display = \"none\";\r\n  panel.classList.add(\"open\");\r\n}\r\n\r\n/* Preview panel tabs */\r\ndocument.querySelectorAll(\".pp-tab\").forEach(tab => {\r\n  tab.addEventListener(\"click\", () => {\r\n    document.querySelectorAll(\".pp-tab\").forEach(t => t.classList.remove(\"active\"));\r\n    tab.classList.add(\"active\");\r\n    const which = tab.dataset.tab;\r\n    $(\"ppCode\").style.display = which === \"code\" ? \"\" : \"none\";\r\n    $(\"ppFrame\").style.display = which === \"preview\" ? \"\" : \"none\";\r\n    $(\"ppTerm\").style.display = which === \"terminal\" ? \"\" : \"none\";\r\n  });\r\n});\r\n$(\"ppClose\").addEventListener(\"click\", () => $(\"previewPanel\").classList.remove(\"open\"));\r\n\r\n/* ============================================================\r\n   In-browser terminal — lightweight JS sandbox\r\n   ============================================================ */\r\nconst termOutput = $(\"termOutput\");\r\nconst termInput = $(\"termInput\");\r\nfunction termPrint(text, cls) {\r\n  const span = document.createElement(\"span\");\r\n  if (cls) span.className = cls;\r\n  span.textContent = text + \"\\n\";\r\n  termOutput.appendChild(span);\r\n  termOutput.scrollTop = termOutput.scrollHeight;\r\n}\r\ntermInput.addEventListener(\"keydown\", (e) => {\r\n  if (e.key !== \"Enter\") return;\r\n  const cmd = termInput.value.trim();\r\n  if (!cmd) return;\r\n  termInput.value = \"\";\r\n  termPrint(\"$ \" + cmd, \"t-prompt\");\r\n  try {\r\n    /* Simple JS eval sandbox */\r\n    const AsyncFunction = Object.getPrototypeOf(async function(){}).constructor;\r\n    const fn = new AsyncFunction(\"require\", \"module\", \"exports\", cmd);\r\n    const fakeModule = { exports: {} };\r\n    const result = fn(require, fakeModule, fakeModule.exports);\r\n    if (result && typeof result.then === \"function\") {\r\n      result.then(r => { if (r !== undefined) termPrint(String(r)); }).catch(err => termPrint(\"Error: \" + err.message, \"t-err\"));\r\n    } else if (result !== undefined) {\r\n      termPrint(String(result));\r\n    }\r\n  } catch (err) {\r\n    termPrint(\"Error: \" + err.message, \"t-err\");\r\n  }\r\n});\r\ntermPrint(\"mizi terminal — type JS expressions. Type clear() to clear.\", \"t-prompt\");\r\n\r\n/* ============================================================\r\n   Subagents — show in the canvas map\r\n   ============================================================ */\r\n/* Subagents are already tracked via map.addSub() in the spawn logic.\r\n   This ensures they appear with proper labels and status colors. */\r\n\r\n</script>\r\n</body>\r\n</html>\r\n";
const server = http.createServer((req, res) => {
  if (req.method === "POST" && req.url.startsWith("/api/")) {
    const body = [];
    req.on("data", c => body.push(c));
    req.on("end", () => {
      const payload = Buffer.concat(body);
      const proxy = https.request({
        hostname: "opencode.ai", port: 443,
        path: "/zen/v1" + req.url.slice(4),
        method: "POST",
        headers: {
          "content-type": req.headers["content-type"] || "application/json",
          authorization: req.headers.authorization || "",
          "content-length": payload.length,
        },
      }, upstream => {
        res.writeHead(upstream.statusCode, {
          "content-type": upstream.headers["content-type"] || "application/json",
          "access-control-allow-origin": "*",
        });
        upstream.pipe(res);
      });
      proxy.on("error", e => {
        if (!res.headersSent) res.writeHead(502, {"content-type":"application/json"});
        res.end(JSON.stringify({error:{message:"proxy: "+e.message}}));
      });
      proxy.write(payload);
      proxy.end();
    });
    return;
  }
  res.writeHead(200, {"content-type":"text/html; charset=utf-8","cache-control":"no-store"});
  res.end(HTML);
});
server.listen(PORT, () => { console.log("\n  mizi running \u2192 http://localhost:" + PORT + "\n"); });

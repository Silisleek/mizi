{
  "name": "@silisleek/mizi",
  "version": "2.1.0",
  "type": "module",
  "description": "AI coding assistant CLI — like Claude Code but open. Chat, run commands, edit files.",
  "main": "lib/repl.js",
  "bin": {
    "mizi": "bin/mizi"
  },
  "files": [
    "bin",
    "lib",
    "mizi.html"
  ],
  "scripts": {
    "build": "node build.js",
    "dev:app": "npm run build && node --experimental-vm-modules node_modules/.bin/vite --config vite.config.js --port 5173 --open",
    "dev:server": "node --experimental-vm-modules server.js",
    "start": "node bin/mizi",
    "serve": "node bin/mizi serve"
  },
  "keywords": [
    "cli",
    "mizi",
    "ai",
    "coding",
    "assistant"
  ],
  "license": "ISC",
  "dependencies": {
    "@types/react": "^19.2.17",
    "ink": "^7.1.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.7"
  }
}
